  <script>
    function selectVariant(btn) {
      const card = btn.closest('.product-card');

      const priceValue = parseFloat(btn.dataset.priceValue);
      const compareValue = parseFloat(btn.dataset.compareValue);
      const price = btn.dataset.price;
      const compare = btn.dataset.compare;
      const variantId = btn.dataset.id;

      // Price elements
      const salePriceEl = card.querySelector('.price-item--sale');
      const regularPriceEl = card.querySelector('.price-item--regular');
      const comparePriceEl = card.querySelector('.price__sale s');

      // Badge
      const badge = card.querySelector('.badge--sale');

      // Form input
      const variantInput = card.querySelector('input[name="id"]');

      // ✅ Update prices
      if (salePriceEl) salePriceEl.innerText = `${price}`;
      if (regularPriceEl) regularPriceEl.innerText = `${price}`;
      if (comparePriceEl) comparePriceEl.innerText = `${compare}`;

      if (comparePriceEl && compareValue > priceValue) {
        comparePriceEl.style.display = 'inline-block';
      } else if (comparePriceEl) {
        comparePriceEl.style.display = 'none';
      }

      // ✅ Update discount badge
      if (badge && compareValue > priceValue) {
        const discount = Math.round(((compareValue - priceValue) / compareValue) * 100);
        badge.innerText = `${discount}% off`;
        badge.style.display = 'inline-block';
      } else if (badge) {
        badge.style.display = 'none';
      }

      // ✅ Update variant ID in form
      if (variantInput) {
        variantInput.value = variantId;
      }

      // ✅ Active state (optional UX)
      const buttons = card.querySelectorAll('.variant-buttons button');
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    }
  </script>
