{% capture lazyloadcss %}
<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
<script src="https://static-cdn.trackier.com/rtg/69c63262ad28df4db2314355.js" defer="defer">
</script>


<!-- Gokwik theme code start -->


<link rel="dns-prefetch" href="https://pdp.gokwik.co/">
<link rel="dns-prefetch" href="https://api.gokwik.co">
{% render 'gokwik' %}
<!-- Gokwik theme code End -->

    {% if template contains 'product' and product.selected_variant == blank and product.metafields.custom.best_selling_variant != blank %}
      <script>
        var redirectUrl = "{{ product.metafields.custom.best_selling_variant.value.url }}";
        if (redirectUrl && window.location.href !== redirectUrl) {
          window.location.replace(redirectUrl);
        }
      </script>
    {% endif %}
    {% render 'head-content' %}
    <meta charset="utf-8">
    <link rel="preconnect" href="https://rs.emagecdn.com">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    <meta name="google-site-verification" content="x_Zin290Mbo0gehmibUmgkRlv3WTMKWdEemt1lYgKWc"/>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- if settings.seo_title_tag_store_name %} &ndash; {{ shop.name }}{% endif -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags', page_description: page_description, page_title: page_title  %}

    <script src="{{ 'constants.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'pubsub.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>

    {%- liquid
      # Fonts
      assign header_font_italic = settings.type_header_font | font_modify: 'style', 'italic'
      assign header_font_medium = settings.type_header_font | font_modify: 'weight', '500'
      assign header_font_bold = settings.type_header_font | font_modify: 'weight', 'bold'
      assign header_font_bold_italic = header_font_bold | font_modify: 'style', 'italic'

      assign body_font_medium = settings.type_body_font | font_modify: 'weight', '500'
      assign body_font_bold = settings.type_body_font | font_modify: 'weight', 'bold'
      assign body_font_italic = settings.type_body_font | font_modify: 'style', 'italic'
      assign body_font_bold_italic = body_font_bold | font_modify: 'style', 'italic'

      assign article_header_font_bold = settings.type_article_header_font | font_modify: 'weight', 'bold'
      assign article_header_font_italic = settings.type_article_header_font | font_modify: 'style', 'italic'
      assign article_header_font_bold_italic = article_header_font_bold | font_modify: 'style', 'italic'
    -%}

    {%- unless settings.type_body_font.system? -%}
      <link rel="preload" href="{{ settings.type_body_font | font_url }}" as="font" crossorigin fetchpriority="high" type="font/woff2">
    {%- endunless -%}

    {%- unless settings.type_header_font.system? or settings.type_header_font == settings.type_body_font -%}
      <link rel="preload" href="{{ settings.type_header_font | font_url }}" as="font" crossorigin fetchpriority="high" type="font/woff2">
    {%- endunless -%}

    {%- unless request.page_type != 'article' or settings.type_article_header_font.system? or settings.type_article_header_font == settings.type_body_font or settings.type_article_header_font == settings.type_header_font -%}
      <link rel="preload" href="{{ settings.type_article_header_font | font_url }}" as="font" crossorigin fetchpriority="high" type="font/woff2">
    {%- endunless -%}

    {%- if settings.animations_reveal_on_scroll -%}
      <script src="{{ 'animations.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    <script src="{{ 'details-disclosure.js' | asset_url }}" defer="defer"></script>

    {%- if request.design_mode -%}
      <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {%- if request.design_mode or template contains 'cart' or template contains 'checkout' -%}
      {{ content_for_header }}
    {%- else -%}
      {% capture content_for_header2 %}{{ content_for_header }}{% endcapture %}
      {{ content_for_header2 | replace: ' async="async" ', ' type="load" ' | replace: ' defer="defer" ', ' type="load" ' | replace: " src=", " d-src="| replace: "DOMContentLoaded", "xDOMContentLoaded" | replace: "window.addEventListener('load', asyncLoad, false);", "window.addEventListener('xDOMContentLoaded', asyncLoad, false);" | replace: "addEventListener('load', prefetchAssets);", "addEventListener('xDOMContentLoaded', prefetchAssets);" | replace: "type='text/javascript' async=''", "type='load' " | replace: 'type="module" d-', 'dxt="module" type="load" d-' | replace: 'async dxt="module" type="load"', 'dxt="module"' | replace: '<script type="module">', '<script dxt="module" type="load">'| replace: "type='text/javascript' defer='defer' d-src", "type='load' d-src" | replace: '<script>' , '<script type="load">' | replace: 'type="load" d-src="https://shop.app/checkouts/internal/preloads.js', 'type="lload" d-src="https://shop.app/checkouts/internal/preloads.js' }}
      <script>var trekkie=[];trekkie.integrations=!0;window.BOOMR={},window.BOOMR.version=true;</script>
    {%- endif -%}


    {%- liquid
      # Theme constants
      assign card_border_thickness = 0
      assign card_border_opacity = 0
      assign card_shadow_opacity = 0
      assign card_shadow_horizontal_offset = 0
      assign card_shadow_vertical_offset = 0
      assign card_shadow_blur = 0

      assign collection_card_border_thickness = 0
      assign collection_card_border_opacity = 0
      assign collection_card_image_padding = 0
      assign collection_card_shadow_opacity = 0
      assign collection_card_shadow_horizontal_offset = 0
      assign collection_card_shadow_vertical_offset = 0
      assign collection_card_shadow_blur = 0

      assign blog_card_border_thickness = 0
      assign blog_card_border_opacity = 0
      assign blog_card_shadow_opacity = 0
      assign blog_card_shadow_horizontal_offset = 0
      assign blog_card_shadow_vertical_offset = 0
      assign blog_card_shadow_blur = 0

      assign text_boxes_border_thickness = 0
      assign text_boxes_border_opacity = 0
      assign text_boxes_shadow_opacity = 0
      assign text_boxes_shadow_horizontal_offset = 0
      assign text_boxes_shadow_vertical_offset = 0
      assign text_boxes_shadow_blur = 0

      assign media_border_thickness = 0
      assign media_border_opacity = 0
      assign media_shadow_opacity = 0
      assign media_shadow_horizontal_offset = 0
      assign media_shadow_vertical_offset = 0
      assign media_shadow_blur = 0

      assign popup_border_thickness = 1
      assign popup_border_opacity = 8
      assign popup_shadow_opacity = 15
      assign popup_shadow_horizontal_offset = 0
      assign popup_shadow_vertical_offset = 0
      assign popup_shadow_blur = 5

      assign buttons_border_opacity = 100
      assign buttons_shadow_opacity = 0
      assign buttons_shadow_horizontal_offset = 0
      assign buttons_shadow_vertical_offset = 0
      assign buttons_shadow_blur = 0

      assign inputs_border_opacity = 35
      assign inputs_shadow_opacity = 0
      assign inputs_shadow_horizontal_offset = 0
      assign inputs_shadow_vertical_offset = 0
      assign inputs_shadow_blur = 0

      assign variant_pills_border_opacity = inputs_border_opacity
      assign variant_pills_shadow_opacity = 0
      assign variant_pills_shadow_horizontal_offset = 0
      assign variant_pills_shadow_vertical_offset = 0
      assign variant_pills_shadow_blur = 0
    %}

    {% style %}
      {% unless settings.type_body_font.system? -%}
        {{ settings.type_body_font | font_face: font_display: 'fallback' }}
        {{ body_font_bold | font_face: font_display: 'fallback' }}
        {{ body_font_italic | font_face: font_display: 'fallback' }}
        {{ body_font_bold_italic | font_face: font_display: 'fallback' }}
        {{ body_font_medium | font_face: font_display: 'fallback' }}
      {%- endunless -%}

      {%- unless settings.type_header_font == settings.type_body_font or settings.type_header_font.system? -%}
        {{ settings.type_header_font | font_face: font_display: 'fallback' }}
        {{ header_font_bold | font_face: font_display: 'fallback' }}
        {{ header_font_italic | font_face: font_display: 'fallback' }}
        {{ header_font_bold_italic | font_face: font_display: 'fallback' }}
        {{ header_font_medium | font_face: font_display: 'fallback' }}
      {%- endunless -%}

      {%- unless request.page_type != 'article' or settings.type_article_header_font.system? or settings.type_article_header_font == settings.type_body_font or settings.type_article_header_font == settings.type_header_font -%}
        {{ settings.type_article_header_font | font_face: font_display: 'fallback' }}
        {{ article_header_font_bold | font_face: font_display: 'fallback' }}
        {{ article_header_font_italic | font_face: font_display: 'fallback' }}
        {{ article_header_font_bold_italic | font_face: font_display: 'fallback' }}
      {%- endunless -%}

      {%- assign color_schemes_with_heading_gradient = "" -%}
      {% for scheme in settings.color_schemes -%}
        {% assign scheme_classes = scheme_classes | append: ', .color-' | append: scheme.id %}
        {% if forloop.index == 1 -%}
          :root,
        {%- endif %}
        .color-{{ scheme.id }} {
          --color-background: {{ scheme.settings.background.red }},{{ scheme.settings.background.green }},{{ scheme.settings.background.blue }};
        {% if scheme.settings.background_gradient != empty %}
          --gradient-background: {{ scheme.settings.background_gradient }};
        {% else %}
          --gradient-background: {{ scheme.settings.background }};
        {% endif %}

        {% liquid
          assign background_color = scheme.settings.background
          assign background_color_brightness = background_color | color_brightness
          if background_color_brightness <= 26
            assign background_color_contrast = background_color | color_lighten: 50
          elsif background_color_brightness <= 65
            assign background_color_contrast = background_color | color_lighten: 5
          else
            assign background_color_contrast = background_color | color_darken: 25
          endif
        %}

        --color-foreground: {{ scheme.settings.text.red }},{{ scheme.settings.text.green }},{{ scheme.settings.text.blue }};
        --color-heading: {{ scheme.settings.heading.red }},{{ scheme.settings.heading.green }},{{ scheme.settings.heading.blue }};
        --color-background-contrast: {{ background_color_contrast.red }},{{ background_color_contrast.green }},{{ background_color_contrast.blue }};
        --color-shadow: 0, 0, 0;
        --color-button: {{ scheme.settings.button.red }},{{ scheme.settings.button.green }},{{ scheme.settings.button.blue }};
        --color-button-alpha: {{ scheme.settings.button.alpha }};
        {% if scheme.settings.button_background_gradient != blank %}
        --color-button-gradient: {{ scheme.settings.button_background_gradient }};
        {% else %}
          --color-button-gradient: none;
        {% endif %}
        --color-button-text: {{ scheme.settings.button_label.red }},{{ scheme.settings.button_label.green }},{{ scheme.settings.button_label.blue }};
        --color-secondary-button: {{ scheme.settings.background.red }},{{ scheme.settings.background.green }},{{ scheme.settings.background.blue }};
        --color-secondary-button-text: {{ scheme.settings.secondary_button_label.red }},{{ scheme.settings.secondary_button_label.green }},{{ scheme.settings.secondary_button_label.blue }};
        --color-link: {{ scheme.settings.link.red }},{{ scheme.settings.link.green }},{{ scheme.settings.link.blue }};
        --color-caption: {{ scheme.settings.caption.red }},{{ scheme.settings.caption.green }},{{ scheme.settings.caption.blue }};
        --color-badge-foreground: {{ scheme.settings.text.red }},{{ scheme.settings.text.green }},{{ scheme.settings.text.blue }};
        --color-badge-background: {{ scheme.settings.background.red }},{{ scheme.settings.background.green }},{{ scheme.settings.background.blue }};
        --color-badge-border: {{ scheme.settings.text.red }},{{ scheme.settings.text.green }},{{ scheme.settings.text.blue }};
        --payment-terms-background-color: rgb({{ scheme.settings.background.rgb }});

        {% if scheme.settings.heading_background_gradient == blank %}
          --color-heading-gradient-background: none;
          --color-heading-gradient-background-clip: border-box;
          --color-heading-gradient-fill: currentColor;
        {% else %}
          --color-heading-gradient-background: -webkit-{{ scheme.settings.heading_background_gradient }};
          --color-heading-gradient-background-clip: text;
          --color-heading-gradient-fill: transparent;
          {%- assign color_schemes_with_heading_gradient = color_schemes_with_heading_gradient | append: "," | append: ".color-" | append: scheme.id -%}
        {% endif %}

        {% if scheme.settings.accent_gradient == blank %}
          --color-accent-gradient-background: none;
          --color-accent-gradient-background-clip: border-box;
          --color-accent-gradient-fill: currentColor;
        {% else %}
          --color-accent-gradient-background: -webkit-{{ scheme.settings.accent_gradient }};
          --color-accent-gradient-background-clip: text;
          --color-accent-gradient-fill: transparent;
        {% endif %}
      }
      {% endfor %}

      {% if color_schemes_with_heading_gradient != blank %}
        {% comment %}Heading text with gradient background{% endcomment %}
        :is({{ color_schemes_with_heading_gradient | remove_first: ',' }}) :is(h1, h2, h3, h4, h5, h6).inline-richtext a {
          box-shadow: 0 0.2rem 0 0 rgb(var(--color-heading));
        }
      {% endif %}

      {{ scheme_classes | prepend: 'body' }} {
        color: rgb(var(--color-foreground));
        background-color: rgb(var(--color-background));
      }

      :root {
        --font-body-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
        --font-body-style: {{ settings.type_body_font.style }};
        --font-body-weight: {{ settings.type_body_font.weight }};
        --font-body-weight-bold: {{ settings.type_body_font.weight | plus: 300 | at_most: 1000 }};
        --font-body-letter-spacing: {{ settings.body_letter_spacing | plus: 1 | times: 0.001 }}em;

        --font-heading-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
        --font-heading-style: {{ settings.type_header_font.style }};
        --font-heading-weight: {{ settings.type_header_font.weight }};

        {% if request.page_type == 'article' %}
        --font-article-heading-family: {{ settings.type_article_header_font.family }}, {{ settings.type_article_header_font.fallback_families }};
        --font-article-heading-style: {{ settings.type_article_header_font.style }};
        --font-article-heading-weight: {{ settings.type_article_header_font.weight }};
        --font-article-heading-letter-spacing: {{ settings.article_heading_letter_spacing | plus: 1 | times: 0.001 }}em;
        {% endif %}

        --font-button-font-weight: {{ settings.button_text_font_weight }};
        --font-button-case: {{ settings.button_text_transform }};
        --font-button-icon-offset: {% if settings.button_text_transform == 'uppercase' %}-0.1rem{% else %}0.1rem{% endif %};
        --font-button-letter-spacing: {{ settings.button_letter_spacing | plus: 1 | times: 0.01 }}em;
        --font-button-text-size: {% if settings.button_text_transform == 'uppercase' %}1.3rem{% else %}1.5rem{% endif %};

        --font-body-scale: {{ settings.body_scale | divided_by: 100.0 }};
        --font-heading-scale: {{ settings.heading_scale | times: 1.0 | divided_by: settings.body_scale }};
        --font-heading-case: {{ settings.heading_text_transform }};
        --font-heading-letter-spacing: {{ settings.heading_letter_spacing | plus: 1 | times: 0.001 }}em;

        --media-padding: {{ settings.media_padding }}px;
        --media-border-opacity: {{ media_border_opacity | divided_by: 100.0 }};
        --media-border-width: {{ media_border_thickness }}px;
        --media-radius: {{ settings.text_boxes_radius }}px;
        --media-shadow-opacity: {{ media_shadow_opacity | divided_by: 100.0 }};
        --media-shadow-horizontal-offset: {{ media_shadow_horizontal_offset }}px;
        --media-shadow-vertical-offset: {{ media_shadow_vertical_offset }}px;
        --media-shadow-blur-radius: {{ media_shadow_blur }}px;
        --media-shadow-visible: {% if media_shadow_opacity > 0 %}1{% else %}0{% endif %};

        --page-width: {{ settings.page_width | divided_by: 10 }}rem;
        --px-mobile: 2rem;
        --page-width-margin: {% if settings.page_width == '1600' %}2{% else %}0{% endif %}rem;

        --product-card-image-padding: {{ settings.card_image_padding | divided_by: 10.0 }}rem;
        --product-card-image-scale: {{ settings.card_image_scale | divided_by: 100.0 }};
        --product-card-corner-radius: {{ settings.card_corner_radius | divided_by: 10.0 }}rem;
        --product-card-text-alignment: {{ settings.card_text_alignment }};
        --product-card-border-width: {{ card_border_thickness | divided_by: 10.0 }}rem;
        --product-card-border-opacity: {{ card_border_opacity | divided_by: 100.0 }};
        --product-card-shadow-opacity: {{ card_shadow_opacity | divided_by: 100.0 }};
        --product-card-shadow-visible: {% if card_shadow_opacity > 0 %}1{% else %}0{% endif %};
        --product-card-shadow-horizontal-offset: {{ card_shadow_horizontal_offset | divided_by: 10.0 }}rem;
        --product-card-shadow-vertical-offset: {{ card_shadow_vertical_offset | divided_by: 10.0 }}rem;
        --product-card-shadow-blur-radius: {{ card_shadow_blur | divided_by: 10.0 }}rem;
        --product-card-star-color: {{ settings.card_star_color.red }},{{ settings.card_star_color.green }},{{ settings.card_star_color.blue }};

        {% unless settings.card_price_color == blank or settings.card_price_color.alpha == 0 %}
          --product-card-price-color: {{ settings.card_price_color.red }},{{ settings.card_price_color.green }},{{ settings.card_price_color.blue }};
        {% endunless %}

        {% unless settings.card_image_background == blank %}
        --product-card-image-background: {{ settings.card_image_background.red }},{{ settings.card_image_background.green }},{{ settings.card_image_background.blue }},{{ settings.card_image_background.alpha }};
        {% endunless %}

        --collection-card-image-padding: {{ collection_card_image_padding | divided_by: 10.0 }}rem;
        --collection-card-corner-radius: {{ settings.collection_card_corner_radius | divided_by: 10.0 }}rem;
        --collection-card-text-alignment: {{ settings.collection_card_text_alignment }};
        --collection-card-border-width: {{ collection_card_border_thickness | divided_by: 10.0 }}rem;
        --collection-card-border-opacity: {{ collection_card_border_opacity | divided_by: 100.0 }};
        --collection-card-shadow-opacity: {{ collection_card_shadow_opacity | divided_by: 100.0 }};
        --collection-card-shadow-visible: {% if collection_card_shadow_opacity > 0 %}1{% else %}0{% endif %};
        --collection-card-shadow-horizontal-offset: {{ collection_card_shadow_horizontal_offset | divided_by: 10.0 }}rem;
        --collection-card-shadow-vertical-offset: {{ collection_card_shadow_vertical_offset | divided_by: 10.0 }}rem;
        --collection-card-shadow-blur-radius: {{ collection_card_shadow_blur | divided_by: 10.0 }}rem;
        --collection-card-image-background: {{ settings.collection_card_image_background.red }},{{ settings.collection_card_image_background.green }},{{ settings.collection_card_image_background.blue }},{{ settings.collection_card_image_background.alpha }};

        --blog-card-image-padding: {{ settings.blog_card_image_padding | divided_by: 10.0 }}rem;
        --blog-card-corner-radius: {{ settings.blog_card_corner_radius | divided_by: 10.0 }}rem;
        --blog-card-border-width: {{ blog_card_border_thickness | divided_by: 10.0 }}rem;
        --blog-card-border-opacity: {{ blog_card_border_opacity | divided_by: 100.0 }};
        --blog-card-shadow-opacity: {{ blog_card_shadow_opacity | divided_by: 100.0 }};
        --blog-card-shadow-visible: {% if blog_card_shadow_opacity > 0 %}1{% else %}0{% endif %};
        --blog-card-shadow-horizontal-offset: {{ blog_card_shadow_horizontal_offset | divided_by: 10.0 }}rem;
        --blog-card-shadow-vertical-offset: {{ blog_card_shadow_vertical_offset | divided_by: 10.0 }}rem;
        --blog-card-shadow-blur-radius: {{ blog_card_shadow_blur | divided_by: 10.0 }}rem;
        --blog-card-image-background: {{ settings.blog_card_image_background.red }},{{ settings.blog_card_image_background.green }},{{ settings.blog_card_image_background.blue }},{{ settings.blog_card_image_background.alpha }};

        {% liquid
          # Determine the font size
          if settings.badge_text_size == "xs"
            assign badge_font_size = "1rem"
          elsif settings.badge_text_size == "s"
            assign badge_font_size = "1.1rem"
          elsif settings.badge_text_size == "m"
            assign badge_font_size = "1.2rem"
          elsif settings.badge_text_size == "l"
            assign badge_font_size = "1.3rem"
          elsif settings.badge_text_size == "xl"
            assign badge_font_size = "1.5rem"
          endif
        %}

        --badge-text-size: {{ badge_font_size }};
        --badge-text-weight: {{ settings.badge_text_weight }};
        --badge-border-width: 1px;
        --badge-border-style: solid;

        --badge-sold-out-foreground: {{ settings.badge_sold_out_text_color.rgba }};
        --badge-sold-out-border: {{ settings.badge_sold_out_border_color.rgba }};
        --badge-sold-out-background: {% if settings.badge_sold_out_background_gradient != blank %}{{ settings.badge_sold_out_background_gradient }}{% else %}{{ settings.badge_sold_out_bg_color }}{% endif %};
        {% if settings.badge_custom_show %}
        --badge-custom-foreground: {{ settings.badge_custom_text_color.rgba }};
        --badge-custom-border: {{ settings.badge_custom_border_color.rgba }};
        --badge-custom-background: {% if settings.badge_custom_background_gradient != blank %}{{ settings.badge_custom_background_gradient }}{% else %}{{ settings.badge_custom_bg_color }}{% endif %};
        {% endif %}
        {% if settings.badge_preorder_show or settings.badge_preorder_show_cart %}
        --badge-preorder-foreground: {{ settings.badge_preorder_text_color.rgba }};
        --badge-preorder-border: {{ settings.badge_preorder_border_color.rgba }};
        --badge-preorder-background: {% if settings.badge_preorder_background_gradient != blank %}{{ settings.badge_preorder_background_gradient }}{% else %}{{ settings.badge_preorder_bg_color }}{% endif %};
        {% endif %}
        {% if settings.badge_new_show %}
        --badge-new-foreground: {{ settings.badge_new_text_color.rgba }};
        --badge-new-border: {{ settings.badge_new_border_color.rgba }};
        --badge-new-background: {% if settings.badge_new_background_gradient != blank %}{{ settings.badge_new_background_gradient }}{% else %}{{ settings.badge_new_bg_color }}{% endif %};
        {% endif %}
        {% if settings.badge_sale_show %}
        --badge-sale-foreground: {{ settings.badge_sale_text_color.rgba }};
        --badge-sale-border: {{ settings.badge_sale_border_color.rgba }};
        --badge-sale-background: {% if settings.badge_sale_background_gradient != blank %}{{ settings.badge_sale_background_gradient }}{% else %}{{ settings.badge_sale_bg_color }}{% endif %};
        {% endif %}

        --popup-border-width: {{ popup_border_thickness }}px;
        --popup-border-opacity: {{ popup_border_opacity | divided_by: 100.0 }};
        --popup-corner-radius: {{ settings.popup_corner_radius }}px;
        --promo-corner-radius: {{ settings.promo_corner_radius }}px;
        --popup-shadow-opacity: {{ popup_shadow_opacity | divided_by: 100.0 }};
        --popup-shadow-horizontal-offset: {{ popup_shadow_horizontal_offset }}px;
        --popup-shadow-vertical-offset: {{ popup_shadow_vertical_offset }}px;
        --popup-shadow-blur-radius: {{ popup_shadow_blur }}px;

        --drawer-border-width: {{ settings.drawer_border_thickness }}px;
        --drawer-border-opacity: {{ settings.drawer_border_opacity | divided_by: 100.0 }};
        --drawer-shadow-opacity: {{ settings.drawer_shadow_opacity | divided_by: 100.0 }};
        --drawer-shadow-horizontal-offset: {{ settings.drawer_shadow_horizontal_offset }}px;
