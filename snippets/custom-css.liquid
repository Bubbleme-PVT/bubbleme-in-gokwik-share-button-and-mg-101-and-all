<style>
html:not(.xh) ul.product-grid li.grid__item:nth-child(n+3) img,
html:not(.xh) .product__media img[d-src],
html:not(.xh) button.thumbnail img[d-src],
html:not(.xh) .product-combos img[d-src],
html:not(.xh) .index-template main#MainContent > *:nth-child(n+4) img[d-src],
html:not(.xh) .hs-image img[d-src],
html:not(.xh) .pdc-svgz-desc img[d-src]{
    opacity: 0;
}
@media (prefers-reduced-motion: no-preference) {
    html:not(.scld) .scroll-trigger.animate--fade-in, 
    html:not(.scld) .scroll-trigger.animate--slide-in {
        opacity: 1 !important;
    }
    html:not(.xh) .scroll-trigger.animate--slide-in {
        transform: none !important;
    }    
}
div#sticky-cta quantity-input {
    display: grid !important;
}
@media screen and (max-width: 749px) {
    .section-featured-collection .slider--tablet.grid--peek {
        margin: 0 !important;
    }          
    .section-product-page .sticky-cta__button {
        max-width: 100%;
    }
}
div#sticky-cta > * {
    width: fit-content;
}

div#sticky-cta {
    justify-content: center;
    background: #fff !important;
    padding: 5px;
    gap: 20px;
    row-gap: 10px;
    flex-wrap: wrap;
}
div#sticky-cta span.price-item {
    color: #215174;
}
.section-product-page .sticky-cta .button {
    padding: 0 !important;
    height: calc(26px + var(--px-mobile) + 2px) !important;
    border-radius: 35px !important;
}
.sticky-offers {
    display: flex !important;
    flex-direction: column;
    --tw-bg-opacity: 1;
    background-color: rgb(240 240 240);
    width: 100% !important;
    align-items: center;
    height: 36px;
    overflow: hidden;
    position: relative;
    transition: opacity .3s ease, transform .3s ease;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    border-radius: 10px;
}
.product-template scroll-to-top-button {
    bottom: 105px !important;
}
.banner-slide {
    position: absolute;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    padding: 0 16px;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
}

.gap-1 {
    gap: .25rem;
}

.text-center {
    text-align: center;
}

.banner-slide img {
    height: 25px;
    width: 40px;
    object-fit: contain;
}

.text-sm {
    font-size: 14px;
    line-height: 1.25rem;
    margin: 0;
}

.leading-\[0\.938rem\] {
    line-height: 15px;
}

.text-\[\#191415\] {
    --tw-text-opacity: 1;
    color: rgb(25 20 21 / var(--tw-text-opacity, 1));
    font-weight: 500;
}
.flex-row {
    flex-direction: row;
}
.justify-center {
    justify-content: center;
}
.trust-content {
    opacity: 1;
    transform: translate3d(0, 0, 0);
    animation-name: firstSlideAnimation;
    animation-duration: 5s;
    animation-delay: 0s;
    animation-iteration-count: infinite;
    animation-timing-function: ease-in-out;
    will-change: transform, opacity;
}

.payment-content {
    opacity: 0;
    transform: translate3d(0, 100%, 0);
    animation-name: secondSlideAnimation;
    animation-duration: 5s;
    animation-delay: 0s;
    animation-iteration-count: infinite;
    animation-timing-function: ease-in-out;
    will-change: transform, opacity;
}
@keyframes secondSlideAnimation {

    0%,
    45% {
        opacity: 0;
        transform: translate3d(0, 100%, 0)
    }

    50%,
    90% {
        opacity: 1;
        transform: translate3d(0, 0, 0)
    }

    95%,
    96% {
        opacity: 0;
        transform: translate3d(0, -100%, 0)
    }

    100%,
    97% {
        opacity: 0;
        transform: translate3d(0, 100%, 0)
    }
}

@keyframes firstSlideAnimation {

    0%,
    45% {
        opacity: 1;
        transform: translate3d(0, 0, 0)
    }

    50%,
    55% {
        opacity: 0;
        transform: translate3d(0, -100%, 0)
    }

    56%,
    90% {
        opacity: 0;
        transform: translate3d(0, 100%, 0)
    }

    100%,
    95% {
        opacity: 1;
        transform: translate3d(0, 0, 0)
    }
}    
  }
</style>
