{%- liquid
  assign section_id = section.id | replace: '-', '' | replace: '_', '' | downcase
-%}

{%- style -%}
  :root {
    /* Matched to Global Design Language */
    --primary-blue-{{ section_id }}: #215174;
    --heading-dark-{{ section_id }}: #215174;
    --secondary-text-{{ section_id }}: #4B5563;
    --border-light-{{ section_id }}: #E2E8F0;
    --bg-soft-{{ section_id }}: #F8FAFC;
    --accent-yellow-{{ section_id }}: #fcd935;
  }

  #architecture-{{ section_id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    font-family: 'Inter', 'Montserrat', sans-serif;
  }

  .arch-container-{{ section_id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
    align-items: center;
  }

  /* Main Title - Matched to Rituals H2 */
  .arch-text-content h2 {
    font-size: clamp(28px, 5vw, 42px);
    font-weight: 800;
    color: var(--heading-dark-{{ section_id }});
    line-height: 1.1;
    margin-bottom: 40px;
    letter-spacing: -0.02em;
  }

  .arch-item-{{ section_id }} {
    display: flex;
    gap: 20px;
    margin-bottom: 35px;
  }

  /* Circle Label */
  .circle-label-{{ section_id }} {
    width: 48px; 
    height: 48px;
    border-radius: 50%;
    background: var(--bg-soft-{{ section_id }});
    color: var(--primary-blue-{{ section_id }});
    display: flex; 
    align-items: center; 
    justify-content: center;
    font-weight: 800;
    flex-shrink: 0;
    font-size: 20px;
    border: 1px solid var(--border-light-{{ section_id }});
  }

  /* Item Title - Matched to Card Standards */
  .arch-item-text h3 { 
    font-size: 20px; 
    font-weight: 800; 
    color: var(--heading-dark-{{ section_id }}); 
    margin: 0 0 8px; 
    letter-spacing: -0.01em;
  }

  /* Item Text - Matched to Step Text */
  .arch-item-text p { 
    font-size: 15px; 
    color: var(--secondary-text-{{ section_id }}); 
    line-height: 1.6; 
    margin: 0; 
  }

  .dr-note-wrapper {
    position: relative;
    background: #ffffff;
    border-radius: 40px;
    padding: 60px 40px 40px;
    border: 1px solid var(--border-light-{{ section_id }});
    box-shadow: 0 4px 20px rgba(0,0,0,0.03); /* Matched to global shadow */
  }

  /* Badge - Matched to Pill Label style */
  .science-badge-{{ section_id }} {
    position: absolute;
    top: -15px;
    left: 40px;
    background: var(--accent-yellow-{{ section_id }});
    color: var(--heading-dark-{{ section_id }});
    padding: 6px 16px;
    border-radius: 100px;
    font-weight: 800;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    box-shadow: 0 4px 10px rgba(252, 217, 53, 0.2);
  }

  /* Quote - Matched to Extra Bold titles */
  .dr-quote-{{ section_id }} {
    font-size: 22px;
    font-weight: 800;
    color: var(--heading-dark-{{ section_id }});
    line-height: 1.4;
    margin-bottom: 30px;
    border-bottom: 1px solid var(--border-light-{{ section_id }});
    padding-bottom: 30px;
    font-style: italic;
    letter-spacing: -0.01em;
  }

  .dr-profile-{{ section_id }} {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .dr-profile-{{ section_id }} img {
    width: 54px; height: 54px; border-radius: 50%; object-fit: cover;
    border: 2px solid #fff;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
  }

  .dr-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .dr-info h4 { 
    font-size: 16px; 
    font-weight: 800; 
    color: var(--heading-dark-{{ section_id }}); 
    margin: 0; 
  }

  .dr-info span { 
    font-size: 15px; 
    color: #94A3B8; 
    font-weight: 500;
  }

  @media (max-width: 990px) {
    .arch-container-{{ section_id }} { grid-template-columns: 1fr; gap: 60px; }
    .dr-note-wrapper { padding: 50px 30px 30px; }
  }

  @media (max-width: 767px) {
    .arch-text-content h2 { font-size: 28px; }
    .arch-item-text h3 { font-size: 18px; }
    .arch-item-text p { font-size: 14px; }
    .dr-note-wrapper { padding: 40px 20px 25px; border-radius: 32px; }
    .dr-quote-{{ section_id }} { font-size: 18px; }
    .science-badge-{{ section_id }} { left: 20px; }
  }
{%- endstyle -%}

<section id="architecture-{{ section_id }}">
  <div class="arch-container-{{ section_id }}">
    <div class="arch-text-content">
      <h2>{{ section.settings.heading }}</h2>
      
      {% for block in section.blocks %}
        <div class="arch-item-{{ section_id }}" {{ block.shopify_attributes }}>
          <div class="circle-label-{{ section_id }}">{{ block.settings.label_char }}</div>
          <div class="arch-item-text">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="dr-note-wrapper">
      <div class="science-badge-{{ section_id }}">Science Note</div>
      <div class="dr-quote-{{ section_id }}">
        "{{ section.settings.dr_quote }}"
      </div>
      <div class="dr-profile-{{ section_id }}">
        {% if section.settings.dr_image != blank %}
          <img src="{{ section.settings.dr_image | image_url: width: 150 }}" alt="{{ section.settings.dr_name }}" loading="lazy">
        {% else %}
          <div style="width:54px; height:54px; border-radius:50%; background:#eee;"></div>
        {% endif %}
        <div class="dr-info">
          <h4>{{ section.settings.dr_name }}</h4>
          <span>{{ section.settings.dr_title }}</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bio-Architecture Pro",
  "settings": [
    { "type": "header", "content": "Layout Settings" },
    { "type": "range", "id": "max_width", "label": "Max Width", "min": 800, "max": 1400, "step": 50, "default": 1100 },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Bio-Chemical Architecture of Calm" },
    { "type": "textarea", "id": "dr_quote", "label": "Doctor Quote", "default": "Without sufficient magnesium, the nervous system remains in a state of high alert." },
    { "type": "text", "id": "dr_name", "label": "Doctor Name", "default": "Dr. Elena Thorne" },
    { "type": "text", "id": "dr_title", "label": "Doctor Subtitle", "default": "Neuro-Nutrition Specialist" },
    { "type": "image_picker", "id": "dr_image", "label": "Doctor Image" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top Padding", "min": 0, "max": 120, "step": 4, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 0, "max": 120, "step": 4, "default": 80 }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Bio Feature",
      "settings": [
        { "type": "text", "id": "label_char", "label": "Circle Character", "default": "M" },
        { "type": "text", "id": "title", "label": "Title", "default": "NMDA Receptor Regulation" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Magnesium sits in the NMDA receptor, preventing it from being activated by excitatory chemicals." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bio-Architecture Pro",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}