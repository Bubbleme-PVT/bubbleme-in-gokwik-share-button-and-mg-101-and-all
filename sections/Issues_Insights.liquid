{%- liquid
  assign section_id = section.id | replace: '-', '' | replace: '_', '' | downcase
-%}

{%- style -%}
  :root {
    /* Matched to Global Design Language */
    --primary-blue-{{ section_id }}: #215174;
    --heading-dark-{{ section_id }}: #215174;
    --secondary-text-{{ section_id }}: #4B5563;
    --border-light-{{ section_id }}: #E2E8F0;
    --bg-soft-{{ section_id }}: #F8FAFC;
  }

  #sleep-insight-{{ section_id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    font-family: 'Inter', 'Montserrat', sans-serif;
  }

  .sleep-container-{{ section_id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  /* Main Title - Matched to Rituals H2 */
  .sleep-content-{{ section_id }} h2 {
    font-size: clamp(28px, 5vw, 42px);
    font-weight: 800;
    color: var(--heading-dark-{{ section_id }});
    margin: 0 0 15px 0;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  /* Subheading - Matched to 18px Standard */
  .sleep-content-{{ section_id }} .description {
    color: var(--secondary-text-{{ section_id }});
    font-size: 18px;
    line-height: 1.6;
    margin-bottom: 40px;
  }

  .issue-item-{{ section_id }} {
    background: #ffffff;
    padding: 25px;
    border-radius: 24px;
    margin-bottom: 15px;
    display: flex;
    gap: 20px;
    border: 1px solid var(--border-light-{{ section_id }});
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .issue-item-{{ section_id }}:hover {
    border-color: var(--primary-blue-{{ section_id }});
    transform: translateX(8px);
    box-shadow: 0 10px 30px rgba(33, 81, 116, 0.08);
  }

  .issue-icon { font-size: 24px; flex-shrink: 0; }
  
  /* Issue Title - Matched to Card Standards */
  .issue-text h3 { 
    font-size: 20px; 
    font-weight: 800; 
    color: var(--heading-dark-{{ section_id }}); 
    margin: 0 0 6px; 
    letter-spacing: -0.01em;
  }
  
  /* Issue Text - Matched to Step Text */
  .issue-text p { 
    font-size: 15px; 
    color: var(--secondary-text-{{ section_id }}); 
    margin: 0; 
    line-height: 1.5; 
  }

  .sleep-card-image {
    background: var(--bg-soft-{{ section_id }});
    border-radius: 40px;
    padding: 40px;
    position: relative;
    border: 1px solid var(--border-light-{{ section_id }});
  }

  .sleep-card-image img { 
    width: 100%; 
    height: auto;
    border-radius: 20px; 
    object-fit: cover; 
    display: block;
  }

  .quote-box-{{ section_id }} {
    background: #ffffff;
    padding: 25px 30px;
    border-radius: 20px;
    margin: -40px 20px 0;
    position: relative;
    z-index: 2;
    box-shadow: 0 10px 30px rgba(0,0,0,0.04);
    font-style: italic;
    color: var(--secondary-text-{{ section_id }});
    font-size: 15px;
    line-height: 1.6;
    text-align: center;
    border: 1px solid var(--border-light-{{ section_id }});
  }

  @media (max-width: 990px) {
    .sleep-container-{{ section_id }} { gap: 40px; }
  }

  @media (max-width: 767px) {
    .sleep-container-{{ section_id }} { grid-template-columns: 1fr; gap: 40px; }
    .sleep-content-{{ section_id }} h2 { font-size: 28px; }
    .sleep-content-{{ section_id }} .description { font-size: 16px; margin-bottom: 30px; }
    .issue-text h3 { font-size: 18px; }
    .issue-text p { font-size: 14px; }
    .sleep-card-image { padding: 25px; border-radius: 32px; }
    .quote-box-{{ section_id }} { padding: 20px; margin: -30px 10px 0; font-size: 14px; }
  }
{%- endstyle -%}

<section id="sleep-insight-{{ section_id }}">
  <div class="sleep-container-{{ section_id }}">
    <div class="sleep-content-{{ section_id }}">
      <h2>{{ section.settings.heading }}</h2>
      <p class="description">{{ section.settings.subheading }}</p>
      
      <div class="issues-list">
        {% for block in section.blocks %}
          <div class="issue-item-{{ section_id }}" {{ block.shopify_attributes }}>
            <div class="issue-icon">{{ block.settings.icon }}</div>
            <div class="issue-text">
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.text }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="sleep-card-image">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
      <div class="quote-box-{{ section_id }}">
        "{{ section.settings.quote }}"
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Issuse Insights",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What sleep issues feel like" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Biological rhythms are delicate. When the body's internal clock becomes desynchronized, the sensation isn't just 'tiredness'." },
    { "type": "image_picker", "id": "image", "label": "Focus Image" },
    { "type": "textarea", "id": "quote", "label": "Bottom Quote", "default": "Sleep is the golden chain that ties health and our bodies together." },
    { "type": "header", "content": "Style & Layout" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "range", "id": "max_width", "label": "Max Width", "min": 800, "max": 1400, "step": 10, "default": 1200 },
    { "type": "range", "id": "padding_top", "label": "Top Padding", "min": 0, "max": 120, "step": 4, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 0, "max": 120, "step": 4, "default": 80 }
  ],
  "blocks": [
    {
      "type": "issue",
      "name": "Issue Item",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (Emoji or SVG)", "default": "⚡" },
        { "type": "text", "id": "title", "label": "Title", "default": "Tired but wired" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "A hyper-aroused state where your body is exhausted but your mind refuses to disengage." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Issuse Insights"
    }
  ]
}
{% endschema %}