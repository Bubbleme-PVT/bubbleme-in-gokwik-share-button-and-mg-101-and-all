{%- style -%}
  .scrolling-banner-{{ section.id }} {
    overflow: hidden;
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_desktop }}px 0;
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw); /* Forces edge-to-edge on all themes */
  }

  .scrolling-container-{{ section.id }} {
    display: flex;
    width: 100%;
    animation: slide-pause-{{ section.id }} {{ section.settings.speed }}s ease-in-out infinite;
  }

  .image-wrapper-{{ section.id }} {
    min-width: 100vw;
    width: 100vw;
    flex-shrink: 0;
    display: block;
    line-height: 0;
  }

  /* Desktop Image Height */
  .image-wrapper-{{ section.id }} img {
    width: 100%;
    height: {{ section.settings.image_height_desktop }}px;
    object-fit: cover;
    display: block;
  }

  /* Mobile Adjustments */
  @media screen and (max-width: 767px) {
    .scrolling-banner-{{ section.id }} {
      padding: {{ section.settings.padding_mobile }}px 0;
    }
    .image-wrapper-{{ section.id }} img {
      height: {{ section.settings.image_height_mobile }}px;
    }
  }

  /* Slide Logic */
  @keyframes slide-pause-{{ section.id }} {
    0%, 20% { transform: translateX(0); }
    25%, 45% { transform: translateX(-100%); }
    50%, 70% { transform: translateX(-200%); }
    75%, 95% { transform: translateX(-300%); }
    100% { transform: translateX(0); }
  }

  {% if section.settings.pause_on_hover %}
  .scrolling-banner-{{ section.id }}:hover .scrolling-container-{{ section.id }} {
    animation-play-state: paused;
  }
  {% endif %}
{%- endstyle -%}

<div class="scrolling-banner-{{ section.id }}">
  <div class="scrolling-container-{{ section.id }}">
    {%- for block in section.blocks -%}
      <div class="image-wrapper-{{ section.id }}" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img src="{{ block.settings.image | image_url: width: 3000 }}" 
               alt="{{ block.settings.image.alt }}" 
               loading="lazy">
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Responsive Full Slider",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 2,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "Slide Speed (Total Cycle)",
      "default": 12
    },
    {
      "type": "header",
      "content": "Desktop Settings"
    },
    {
      "type": "range",
      "id": "image_height_desktop",
      "min": 0,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "label": "Desktop Image Height",
      "default": 450
    },
    {
      "type": "range",
      "id": "padding_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Desktop Vertical Padding",
      "default": 0
    },
    {
      "type": "header",
      "content": "Mobile Settings"
    },
    {
      "type": "range",
      "id": "image_height_mobile",
      "min": 0,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Mobile Image Height",
      "default": 250
    },
    {
      "type": "range",
      "id": "padding_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Mobile Vertical Padding",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Responsive Full Slider",
      "blocks": [
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}