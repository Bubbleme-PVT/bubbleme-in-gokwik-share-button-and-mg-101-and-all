{%- liquid
  assign section_id = section.id | replace: '-', '' | replace: '_', '' | downcase
-%}

{%- style -%}
  #ing-section-{{ section_id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    font-family: sans-serif;
    overflow: hidden; 
  }

  .ing-title-{{ section_id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto 50px;
    padding: 0 20px;
    color: #1a1a1a;
    font-size: 32px;
    font-weight: 800;
    text-align: {{ section.settings.heading_align }};
  }

  .ing-grid-{{ section_id }} {
    display: flex;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px 20px;
    gap: 30px;
    transition: all 0.3s ease;
  }

  /* Desktop Scroll Logic */
  {% if section.settings.enable_desktop_scroll %}
    .ing-grid-{{ section_id }} {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
    }
    .ing-card-{{ section_id }} {
      flex: 0 0 calc(33.333% - 20px); /* Shows 3 cards with gap */
      scroll-snap-align: start;
    }
    
    /* Custom Scrollbar for Desktop */
    .ing-grid-{{ section_id }}::-webkit-scrollbar {
      height: 4px;
    }
    .ing-grid-{{ section_id }}::-webkit-scrollbar-track {
      background: rgba(0,0,0,0.05);
      border-radius: 10px;
    }
    .ing-grid-{{ section_id }}::-webkit-scrollbar-thumb {
      background: #1a1a1a;
      border-radius: 10px;
    }
  {% else %}
    .ing-grid-{{ section_id }} {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
    }
  {% endif %}

  .ing-card-{{ section_id }} {
    display: flex;
    flex-direction: column;
    background: transparent;
  }

  .ing-card-media {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 40px;
    overflow: hidden;
    margin-bottom: 25px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  .ing-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ing-card-name {
    color: #1a1a1a;
    font-size: 20px;
    font-weight: 700;
    margin: 0 0 10px 0;
    line-height: 1.2;
  }

  .ing-card-desc {
    color: #4a4a4a;
    font-size: 14px;
    line-height: 1.6;
    margin: 0 0 25px 0;
  }

  .ing-card-ritual {
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px solid rgba(0,0,0,0.08);
  }

  .ritual-label {
    text-transform: uppercase;
    font-size: 10px;
    letter-spacing: 1.5px;
    font-weight: 700;
    opacity: 0.5;
    margin-bottom: 5px;
    display: block;
  }

  .ritual-link {
    font-size: 17px;
    font-weight: 700;
    color: #1a1a1a;
    text-decoration: none;
  }

  /* Responsive Adjustments */
  @media (max-width: 990px) {
    {% if section.settings.enable_desktop_scroll %}
       .ing-card-{{ section_id }} { flex: 0 0 calc(50% - 15px); }
    {% else %}
       .ing-grid-{{ section_id }} { grid-template-columns: repeat(2, 1fr); }
    {% endif %}
  }

  @media (max-width: 767px) {
    {% if section.settings.enable_mobile_scroll %}
      .ing-grid-{{ section_id }} {
        display: flex;
        overflow-x: auto;
        gap: 20px;
        scrollbar-width: none;
      }
      .ing-grid-{{ section_id }}::-webkit-scrollbar { display: none; }
      .ing-card-{{ section_id }} {
        flex: 0 0 80%; 
        scroll-snap-align: center;
      }
    {% else %}
      .ing-grid-{{ section_id }} { 
        display: grid;
        grid-template-columns: 1fr; 
      }
    {% endif %}
    .ing-card-media { border-radius: 30px; }
  }
{%- endstyle -%}

<section id="ing-section-{{ section_id }}">
  {% if section.settings.heading != blank %}
    <h2 class="ing-title-{{ section_id }}">{{ section.settings.heading }}</h2>
  {% endif %}
  
  <div class="ing-grid-{{ section_id }}">
    {% for block in section.blocks %}
      <div class="ing-card-{{ section_id }}" {{ block.shopify_attributes }}>
        <div class="ing-card-media">
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
        <div class="ing-card-content">
          <h3 class="ing-card-name">{{ block.settings.title }}</h3>
          <p class="ing-card-desc">{{ block.settings.short_desc }}</p>
          <div class="ing-card-ritual">
            <span class="ritual-label">{{ block.settings.ritual_label }}</span>
            <a href="{{ block.settings.product_link | default: '#' }}" class="ritual-link">
              {{ block.settings.ritual_name }}
            </a>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Ingredient Highlight Grid",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Incorporate these into your ritual" },
    { "type": "select", "id": "heading_align", "label": "Heading Alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"}], "default": "center" },
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#ffffff" },
    { "type": "range", "id": "max_width", "label": "Max Container Width", "min": 800, "max": 1600, "step": 10, "default": 1200 },
    { "type": "checkbox", "id": "enable_desktop_scroll", "label": "Enable Horizontal Scroll (Desktop)", "default": false },
    { "type": "checkbox", "id": "enable_mobile_scroll", "label": "Enable Horizontal Scroll (Mobile)", "default": true },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top Padding", "min": 0, "max": 100, "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 0, "max": 100, "default": 60 }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Better Sleep" },
        { "type": "textarea", "id": "short_desc", "label": "Description", "default": "Designed for those who find it hard to switch off." },
        { "type": "header", "content": "Ritual Footer" },
        { "type": "text", "id": "ritual_label", "label": "Footer Label", "default": "EXPLORE" },
        { "type": "text", "id": "ritual_name", "label": "Product Name", "default": "Magnesium Sleep Spray" },
        { "type": "url", "id": "product_link", "label": "Product Link" }
      ]
    }
  ],
  "presets": [{ "name": "Ingredient Highlight Grid" }]
}
{% endschema %}