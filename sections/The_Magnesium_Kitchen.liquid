{%- liquid
  assign section_id = section.id | replace: '-', '' | replace: '_', '' | downcase
-%}

{%- style -%}
  :root {
    /* Standardized Palette */
    --primary-blue-{{ section_id }}: #215174;
    --heading-dark-{{ section_id }}: #215174;
    --secondary-text-{{ section_id }}: #4B5563;
    --border-light-{{ section_id }}: #E2E8F0;
    --bg-soft-{{ section_id }}: #F8FAFC;
  }

  #kitchen-{{ section_id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    font-family: 'Inter', 'Montserrat', sans-serif;
    overflow: hidden;
  }

  .kitchen-header-{{ section_id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto 40px;
    padding: 0 20px;
    text-align: {{ section.settings.heading_align }};
  }

  /* Main Title - Matched to Rituals H2 */
  .kitchen-header-{{ section_id }} h2 {
    font-size: clamp(28px, 5vw, {{ section.settings.heading_size }}px);
    font-weight: 800;
    margin: 0 0 10px 0;
    color: var(--heading-dark-{{ section_id }});
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  /* Subheading - Matched to Rituals Subheading */
  .kitchen-header-{{ section_id }} p {
    color: var(--secondary-text-{{ section_id }});
    font-size: 18px;
    line-height: 1.6;
    max-width: 600px;
    {% if section.settings.heading_align == 'center' %}margin: 0 auto;{% endif %}
  }

  /* Slider Container */
  .kitchen-slider-wrapper-{{ section_id }} {
    display: flex;
    position: relative;
    {% if section.settings.auto_rotate %}
      overflow: hidden;
    {% else %}
      overflow-x: auto;
      scroll-snap-type: x mandatory;
    {% endif %}
    padding: 10px 0 5px;
    scrollbar-width: none;
    mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
  }

  .kitchen-slider-wrapper-{{ section_id }}::-webkit-scrollbar {
    display: none;
  }

  .kitchen-track-{{ section_id }} {
    display: flex;
    gap: {{ section.settings.grid_gap }}px;
    width: max-content;
    padding: 0 40px;
    {% if section.settings.auto_rotate %}
      animation: kitchen-scroll-{{ section_id }} {{ section.settings.rotation_speed }}s linear infinite;
    {% endif %}
  }

  {% if section.settings.auto_rotate %}
    .kitchen-track-{{ section_id }}:hover {
      animation-play-state: paused;
    }

    @keyframes kitchen-scroll-{{ section_id }} {
      0% { transform: translateX(0); }
      100% { transform: translateX(calc(-50% - ({{ section.settings.grid_gap }}px / 2))); }
    }
  {% endif %}

  .kitchen-card-{{ section_id }} {
    flex: 0 0 240px;
    min-width: 240px;
    background: {{ section.settings.card_bg }};
    border-radius: {{ section.settings.card_roundness }}px;
    padding: 12px 11px;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    box-shadow: 0 4px 20px rgba(0,0,0,0.03); /* Synced Shadow */
    border: 1px solid var(--border-light-{{ section_id }});
  }

  .kitchen-card-{{ section_id }}:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 25px rgba(0,0,0,0.06);
    border-color: var(--primary-blue-{{ section_id }});
  }

  .kitchen-img-wrapper {
    width: {{ section.settings.img_size }}px;
    height: {{ section.settings.img_size }}px;
    border-radius: 50%;
    background: var(--bg-soft-{{ section_id }});
    margin-bottom: 20px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-light-{{ section_id }});
  }

  .kitchen-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Food Name - Matched to Card Titles */
  .food-name-{{ section_id }} {
    font-size: 20px;
    font-weight: 800;
    color: var(--heading-dark-{{ section_id }});
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
  }

  /* Food MG Stats - Matched to Pill Label Style */
  .food-stats-{{ section_id }} {
    font-size: 10px;
    font-weight: 800;
    color: var(--primary-blue-{{ section_id }});
    letter-spacing: 0.12em;
    opacity: 0.9;
  }

  @media (max-width: 767px) {
    .kitchen-slider-wrapper-{{ section_id }} {
       mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
       -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    }
    .kitchen-header-{{ section_id }} h2 { font-size: 28px; }
    .kitchen-header-{{ section_id }} p { font-size: 16px; }
    .kitchen-card-{{ section_id }} {
      flex: 0 0 190px;
      min-width: 190px;
      padding: 30px 15px;
    }
    .food-name-{{ section_id }} { font-size: 18px; }
  }
{%- endstyle -%}

<section class="kitchen-container-master" id="kitchen-{{ section_id }}">
  <div class="kitchen-header-{{ section_id }}">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subheading }}</p>
  </div>

  <div class="kitchen-slider-wrapper-{{ section_id }}">
    <div class="kitchen-track-{{ section_id }}">
      {% assign loop_iterations = 1 %}
      {% if section.settings.auto_rotate %}{% assign loop_iterations = 2 %}{% endif %}

      {% for i in (1..loop_iterations) %}
        {% for block in section.blocks %}
          <div class="kitchen-card-{{ section_id }}" {{ block.shopify_attributes }}>
            <div class="kitchen-img-wrapper">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 300 | image_tag: loading: 'lazy' }}
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>
            <h3 class="food-name-{{ section_id }}">{{ block.settings.title }}</h3>
            <span class="food-stats-{{ section_id }}">{{ block.settings.stats }}</span>
          </div>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "The Magnesium Kitchen",
  "settings": [
    { "type": "header", "content": "Global Layout" },
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#ffffff" },
    { "type": "range", "id": "max_width", "label": "Max Container Width", "min": 800, "max": 1400, "step": 50, "default": 1200 },
    { "type": "range", "id": "grid_gap", "label": "Gap Between Cards", "min": 10, "max": 60, "step": 2, "default": 20 },
    { "type": "header", "content": "Auto-Rotate Settings" },
    { "type": "checkbox", "id": "auto_rotate", "label": "Enable Auto-Rotate", "default": true },
    { "type": "range", "id": "rotation_speed", "label": "Rotation Speed (Seconds)", "min": 5, "max": 60, "step": 5, "default": 25 },
    { "type": "header", "content": "Header Styling" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Magnesium Kitchen" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Start where it counts most: your plate." },
    { "type": "range", "id": "heading_size", "label": "Heading Font Size", "min": 24, "max": 60, "step": 1, "default": 42 },
    { "type": "select", "id": "heading_align", "label": "Alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"}], "default": "center" },
    { "type": "header", "content": "Card Styling" },
    { "type": "color", "id": "card_bg", "label": "Card Background", "default": "#ffffff" },
    { "type": "range", "id": "card_roundness", "label": "Card Corner Radius", "min": 0, "max": 60, "step": 2, "default": 24 },
    { "type": "range", "id": "img_size", "label": "Food Image Size (px)", "min": 60, "max": 120, "step": 5, "default": 90 },
    { "type": "header", "content": "Section Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top Padding", "min": 0, "max": 120, "step": 4, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 0, "max": 120, "step": 4, "default": 80 }
  ],
  "blocks": [
    {
      "type": "food_item",
      "name": "Food Item",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Food Image" },
        { "type": "text", "id": "title", "label": "Food Name", "default": "Dark Chocolate" },
        { "type": "text", "id": "stats", "label": "Stats", "default": "64MG / OZ" }
      ]
    }
  ],
  "presets": [{ "name": "The Magnesium Kitchen" }]
}
{% endschema %}