<style>
#shopify-section-{{ section.id }} .our_partners_sec h2 {
    color: var(--var-000000);
    text-align: center;
    font-size: 36px;
    font-weight: 300;
    line-height: normal;
    letter-spacing: -1.08px;
    margin-bottom: 25px
}

#shopify-section-{{ section.id }} .our_partners_sec {
    padding-top: 30px;
    padding-bottom: 100px;
    overflow: hidden
}

#shopify-section-{{ section.id }} .our_partners_sec .owl-carousel .owl-stage-outer {
    overflow: hidden
}

#shopify-section-{{ section.id }} .our_partners_sec .slider_wrapper {
    position: relative
}

#shopify-section-{{ section.id }} .our_partners_sec .slide_item img {
    width: auto !important;
    margin: auto;
    display: block;
    height: 100%;
    max-height: 100vh;
    max-width: 100%;
    border-radius: 16px
}

@media(max-width:1024px) {

    #shopify-section-{{ section.id }} .our_partners_sec h2{
        font-size: 32px;
        line-height: 40px;
        letter-spacing: 0
    }
}


@media(max-width:575px) {
    #shopify-section-{{ section.id }} .our_partners_sec {
        padding-top: 20px;
        padding-bottom: 80px
    }

    #shopify-section-{{ section.id }} .our_partners_sec h2{
        margin-bottom: 20px;
        font-size: 28px;
        line-height: 38px
    }
}
</style>
<div class="our_partners_sec">
    <div class="container page-width">
        <div class="main_wrapper">
            <h2>{{ section.settings.title }}</h2>
            <div class="slider_wrapper">
                <div class="owl-carousel owl-theme">
                    {% for block in section.blocks %}
                        <div class="item">
                            <div class="slide_item
                                {% if block.settings.image == blank %}
                                    empty
                                {% endif %}">
                                <a href="{% if block.settings.link != nil %}{{ block.settings.link }}{% else %}javascript:;{% endif %}">
                                    {{ block.settings.image | image_url: width: block.settings.image.width, height: block.settings.image.height | image_tag: loading: 'lazy' }}
                                </a>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>
<link rel="stylesheet" d-href="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/assets/owl.carousel.min.css" integrity="sha512-tS3S5qG0BlhnQROyJXvNjeEM4UpMXHrQfTGmbQ1gKmelCxlSEBUaxhRBj/EFTzpbP4RVSrpEikbmdJobCvhE3g==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<script type="load" d-src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
<script type="load" d-src="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/owl.carousel.min.js"></script>
<script type="load">
jQuery('.our_partners_sec .owl-carousel').owlCarousel({
        loop: true,
        {% if section.settings.autoplay == true %}
        autoplay:true,
        autoplayTimeout:3000,
        autoplayHoverPause:true,
        {% endif %}
        margin: 20,
        nav: false,
        dots: false,
        autoHeight : true,
        responsive:{
            0:{
                items:{{ section.settings.mobile_slides }}
            },
            600:{
                items:{{ section.settings.desktop_slides | minus: 1 }}
            },
            1000:{
                items:{{ section.settings.desktop_slides }}
            }
        }
    });  
</script>


{% schema %}
    {
        "name": "Partner Slider",
        "settings": [
                {
                    "type": "checkbox",
                    "id": "autoplay",
                    "label": "Autoplay",
                    "default": false
                },
                {
                    "type": "text",
                    "id": "title",
                    "label": "Title",
                    "default": "Our Partners and Certifications"
                },
                {
                    "type": "range",
                    "id": "desktop_slides",
                    "min": 1,
                    "max": 10,
                    "default": 3,
                    "label": "Desktop Slides"
                },
                {
                    "type": "range",
                    "id": "mobile_slides",
                    "min": 1,
                    "max": 10,
                    "default": 3,
                    "label": "Mobile Slides"
                }

        ],
        "blocks": [
            {
                "type": "image_picker",
                "name": "Image",
                "settings": [
                        {
                            "type": "image_picker",
                            "id": "image",
                            "label": "Image"
                        },
                        {
                            "type": "url",
                            "id": "link",
                            "label": "Link"
                        }
                ]
            }
        ],
        "presets": [
            {
            "name": "Partner Slider"
            }
        ]
    }
{% endschema %}