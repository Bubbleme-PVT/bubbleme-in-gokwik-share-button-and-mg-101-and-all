{%- liquid
  assign section_id = section.id | replace: '-', '' | replace: '_', '' | downcase
-%}

{%- style -%}
  :root {
    /* Matched to Global Design Language */
    --primary-blue-{{ section_id }}: #215174;
    --heading-dark-{{ section_id }}: #215174;
    --secondary-text-{{ section_id }}: #4B5563;
    --border-light-{{ section_id }}: #E2E8F0;
    --bg-soft-{{ section_id }}: #F8FAFC;
  }

  .comp-{{ section_id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    font-family: 'Inter', 'Montserrat', sans-serif;
  }
  
  .comp-outer-card-{{ section_id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    background: #ffffff;
    border-radius: 48px;
    padding: 80px 60px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03); /* Matched to global shadow */
    text-align: center;
    border: 1px solid var(--border-light-{{ section_id }});
  }

  /* Main Title - Matched to Rituals H2 */
  .comp-header-{{ section_id }} h2 {
    font-size: clamp(28px, 5vw, 42px);
    font-weight: 800;
    margin: 0 0 15px;
    color: var(--heading-dark-{{ section_id }});
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  /* Subheading - Matched to Rituals Standard */
  .comp-header-{{ section_id }} p {
    font-size: 18px;
    color: var(--secondary-text-{{ section_id }});
    line-height: 1.6;
    max-width: 650px;
    margin: 0 auto 60px;
  }

  .acc-item-{{ section_id }} {
    background: #ffffff;
    border: 1px solid var(--border-light-{{ section_id }});
    border-radius: 32px; /* Matched to Rituals Card */
    margin-bottom: 20px;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    text-align: left;
    overflow: hidden;
  }
  
  .acc-item-{{ section_id }}.active {
    border-color: var(--primary-blue-{{ section_id }});
    box-shadow: 0 10px 30px rgba(33, 81, 116, 0.05);
  }

  .acc-trigger-{{ section_id }} {
    width: 100%;
    padding: 30px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: transparent;
    border: none;
    cursor: pointer;
  }

  /* Accordion Title - Matched to Card Titles */
  .acc-title-wrap-{{ section_id }} {
    display: flex;
    align-items: center;
    gap: 20px;
    font-size: 22px;
    font-weight: 800;
    color: var(--heading-dark-{{ section_id }});
    letter-spacing: -0.01em;
    text-align: left;
  }

  .status-icon-{{ section_id }} {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 800;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.05);
  }

  .acc-content-{{ section_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s ease-in-out, padding 0.3s ease;
    padding: 0 40px;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 40px;
  }

  .acc-item-{{ section_id }}.active .acc-content-{{ section_id }} {
    max-height: 2000px;
    padding: 10px 40px 50px;
    border-top: 1px solid var(--bg-soft-{{ section_id }});
  }

  .acc-left-{{ section_id }} { padding-top: 30px; }

  /* Eyebrow Label - Matched to Pill Label style */
  .small-label-{{ section_id }} {
    font-size: 10px;
    font-weight: 800;
    color: var(--primary-blue-{{ section_id }});
    text-transform: uppercase;
    letter-spacing: 0.12em;
    display: block;
    margin-bottom: 20px;
    opacity: 0.9;
  }

  /* Main Accordion Text - Matched to Step Text */
  .acc-left-{{ section_id }} p {
    font-size: 15px;
    color: var(--secondary-text-{{ section_id }});
    line-height: 1.6;
    margin-bottom: 40px;
  }

  .stats-grid-{{ section_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
  }
  
  .stat-pill-{{ section_id }} {
    background: var(--bg-soft-{{ section_id }});
    padding: 20px 15px;
    border-radius: 20px;
    flex: 1 1 calc(33.33% - 15px);
    min-width: 100px;
    text-align: center;
    border: 1px solid var(--border-light-{{ section_id }});
  }
  
  /* Stat Number - Matched to Bold Titles */
  .stat-pill-{{ section_id }} strong {
    display: block;
    font-size: 24px;
    color: var(--primary-blue-{{ section_id }});
    margin-bottom: 6px;
    font-weight: 800;
    letter-spacing: -0.01em;
  }
  
  /* Stat Text - Matched to Pill Label style */
  .stat-pill-{{ section_id }} span {
    font-size: 10px;
    font-weight: 800;
    color: #94A3B8;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .acc-right-{{ section_id }} {
    background: var(--bg-soft-{{ section_id }});
    border-radius: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px;
    margin-top: 30px;
    border: 1px solid var(--border-light-{{ section_id }});
  }

  .diagram-box-{{ section_id }} {
    background: #ffffff;
    border-radius: 16px;
    padding: 20px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03); /* Synced */
    width: 100%;
  }
  
  /* Caption Text - Matched to Step Text */
  .diagram-caption-{{ section_id }} {
    margin-top: 20px;
    font-size: 15px;
    color: var(--secondary-text-{{ section_id }});
    line-height: 1.6;
    text-align: center;
  }

  .chevron-{{ section_id }} {
    color: var(--primary-blue-{{ section_id }});
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    flex-shrink: 0;
  }
  
  .acc-item-{{ section_id }}.active .chevron-{{ section_id }} {
    transform: rotate(180deg);
  }

  /* MOBILE RESPONSIVE OVERRIDES */
  @media (max-width: 768px) {
    .comp-{{ section_id }} { padding-left: 15px; padding-right: 15px; }
    
    .comp-outer-card-{{ section_id }} { 
      padding: 50px 20px; 
      border-radius: 32px; 
    }

    .comp-header-{{ section_id }} h2 { font-size: 28px; }
    .comp-header-{{ section_id }} p { font-size: 16px; margin-bottom: 40px; }

    .acc-trigger-{{ section_id }} { padding: 25px 20px; }

    .acc-title-wrap-{{ section_id }} { 
      font-size: 18px; 
      gap: 15px; 
    }

    .status-icon-{{ section_id }} {
      width: 36px;
      height: 36px;
      font-size: 16px;
    }

    .acc-content-{{ section_id }} { 
      grid-template-columns: 1fr; 
      padding: 0 20px; 
      gap: 20px;
    }

    .acc-item-{{ section_id }}.active .acc-content-{{ section_id }} {
      padding: 10px 20px 30px;
    }

    .acc-left-{{ section_id }} { padding-top: 20px; }
    
    .acc-left-{{ section_id }} p { font-size: 14px; margin-bottom: 25px; }

    .stat-pill-{{ section_id }} { 
      flex: 1 1 calc(50% - 15px); /* 2 per row on mobile */
      padding: 15px 10px;
    }

    .stat-pill-{{ section_id }} strong { font-size: 20px; }

    .acc-right-{{ section_id }} {
      padding: 25px 20px;
      margin-top: 10px;
    }

    .diagram-caption-{{ section_id }} { font-size: 14px; }
  }
{%- endstyle -%}

<section class="comp-{{ section_id }}" id="comp-{{ section_id }}">
  <div class="comp-outer-card-{{ section_id }}">
    
    <div class="comp-header-{{ section_id }}">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>
    </div>

    <div class="accordion-wrap-{{ section_id }}">
      {% for block in section.blocks %}
        <div class="acc-item-{{ section_id }} {% if forloop.first and section.settings.open_first %}active{% endif %}" {{ block.shopify_attributes }}>
          
          <button class="acc-trigger-{{ section_id }}" type="button" aria-expanded="{% if forloop.first and section.settings.open_first %}true{% else %}false{% endif %}">
            <div class="acc-title-wrap-{{ section_id }}">
              <div class="status-icon-{{ section_id }}" 
                   style="background-color: {{ block.settings.icon_bg }}; color: var(--primary-blue-{{ section_id }});">
                {{ block.settings.icon_text }}
              </div>
              {{ block.settings.title }}
            </div>
            <div class="chevron-{{ section_id }}">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </div>
          </button>

          <div class="acc-content-{{ section_id }}">
            <div class="acc-left-{{ section_id }}">
              <span class="small-label-{{ section_id }}">{{ block.settings.small_label }}</span>
              <p>{{ block.settings.description }}</p>
              
              <div class="stats-grid-{{ section_id }}">
                {% if block.settings.s1_v != blank %}
                  <div class="stat-pill-{{ section_id }}"><strong>{{ block.settings.s1_v }}</strong><span>{{ block.settings.s1_l }}</span></div>
                {% endif %}
                {% if block.settings.s2_v != blank %}
                  <div class="stat-pill-{{ section_id }}"><strong>{{ block.settings.s2_v }}</strong><span>{{ block.settings.s2_l }}</span></div>
                {% endif %}
                {% if block.settings.s3_v != blank %}
                  <div class="stat-pill-{{ section_id }}"><strong>{{ block.settings.s3_v }}</strong><span>{{ block.settings.s3_l }}</span></div>
                {% endif %}
              </div>
            </div>

            <div class="acc-right-{{ section_id }}">
              <div class="diagram-box-{{ section_id }}">
                {% if block.settings.diagram_image != blank %}
                  <img src="{{ block.settings.diagram_image | image_url: width: 600 }}" style="width:100%; height:auto; border-radius: 8px;" loading="lazy" alt="{{ block.settings.title }}">
                {% else %}
                  <div style="padding:40px; color:#cbd5e1; font-weight:800; font-size: 10px; text-transform: uppercase; letter-spacing: 0.12em; text-align:center;">[ Molecular Diagram ]</div>
                {% endif %}
              </div>
              {% if block.settings.caption != blank %}
                <p class="diagram-caption-{{ section_id }}">{{ block.settings.caption }}</p>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const accordionContainer = document.querySelector('#comp-{{ section_id }}');
    const triggers = accordionContainer.querySelectorAll('.acc-trigger-{{ section_id }}');

    triggers.forEach(trigger => {
      trigger.addEventListener('click', function() {
        const item = this.parentElement;
        const isActive = item.classList.contains('active');
        
        // Close all items
        accordionContainer.querySelectorAll('.acc-item-{{ section_id }}').forEach(i => {
          i.classList.remove('active');
          i.querySelector('.acc-trigger-{{ section_id }}').setAttribute('aria-expanded', 'false');
        });

        // Toggle clicked item
        if (!isActive) {
          item.classList.add('active');
          this.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Why Composition Matters",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Composition Matters" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Bio-availability isn't just a buzzword. True absorption starts at the molecular level." },
    { "type": "checkbox", "id": "open_first", "label": "Open First Item Default", "default": true },
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#ffffff" },
    { "type": "range", "id": "max_width", "label": "Max Width", "min": 800, "max": 1200, "step": 10, "default": 1100 },
    { "type": "range", "id": "padding_top", "label": "Padding Top", "min": 0, "max": 120, "step": 4, "default": 100 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 0, "max": 120, "step": 4, "default": 100 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Accordion Item",
      "settings": [
        { "type": "header", "content": "Header Settings" },
        { "type": "text", "id": "title", "label": "Title", "default": "Chelated & Complexed" },
        { "type": "text", "id": "icon_text", "label": "Status Icon (Emoji or SVG)", "default": "✓" },
        { "type": "color", "id": "icon_bg", "label": "Icon Circle BG", "default": "#F0F9FF" },
        { "type": "header", "content": "Content Settings" },
        { "type": "text", "id": "small_label", "label": "Upper Label", "default": "THE CLINICAL ADVANTAGE" },
        { "type": "textarea", "id": "description", "label": "Text", "default": "Magnesium bonded to amino acids mimics the way nutrients are found in nature, facilitating superior transport." },
        { "type": "header", "content": "Stats" },
        { "type": "text", "id": "s1_v", "label": "S1 Value", "default": "80%" },
        { "type": "text", "id": "s1_l", "label": "S1 Label", "default": "Bioavailability" },
        { "type": "text", "id": "s2_v", "label": "S2 Value", "default": "92%" },
        { "type": "text", "id": "s2_l", "label": "S2 Label", "default": "Cellular Uptake" },
        { "type": "text", "id": "s3_v", "label": "S3 Value", "default": "High" },
        { "type": "text", "id": "s3_l", "label": "S3 Label", "default": "GI Comfort" },
        { "type": "header", "content": "Diagram Settings" },
        { "type": "image_picker", "id": "diagram_image", "label": "Diagram Image" },
        { "type": "textarea", "id": "caption", "label": "Diagram Caption", "default": "Chelated molecules act as a 'trojan horse' moving effortlessly through the intestinal wall." }
      ]
    }
  ],
  "presets": [{ "name": "Why Composition Matters" }]
}
{% endschema %}