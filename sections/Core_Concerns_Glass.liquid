{%- liquid
  assign section_id = section.id | replace: '-', '' | replace: '_', '' | downcase
-%}

{%- style -%}
  :root {
    /* Matched to Global Design Language */
    --primary-blue-{{ section_id }}: #215174;
    --heading-dark-{{ section_id }}: #215174;
    --secondary-text-{{ section_id }}: #4B5563;
    --border-light-{{ section_id }}: #E2E8F0;
  }

  #concerns-{{ section_id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    font-family: 'Inter', 'Montserrat', sans-serif;
  }

  /* DESKTOP HIDE LOGIC */
  {% if section.settings.hide_cards_desktop %}
    .concerns-grid-{{ section_id }} { display: none !important; }
  {% endif %}

  .concerns-container-{{ section_id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .concerns-header-{{ section_id }} {
    text-align: {{ section.settings.heading_align }};
    margin-bottom: 40px;
  }

  /* Main Title - Matched to Rituals H2 */
  .concerns-header-{{ section_id }} h2 {
    font-size: clamp(28px, 5vw, {{ section.settings.heading_size }}px);
    font-weight: 800;
    color: var(--heading-dark-{{ section_id }});
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
  }

  /* Subheading - Matched to Rituals Subheading */
  .concerns-subheading-{{ section_id }} {
    font-size: 18px;
    color: var(--secondary-text-{{ section_id }});
    margin-top: 15px;
    max-width: 650px;
    line-height: 1.6;
    margin-left: {% if section.settings.heading_align == 'center' %}auto{% else %}0{% endif %};
    margin-right: {% if section.settings.heading_align == 'center' %}auto{% else %}0{% endif %};
  }

  .concerns-grid-{{ section_id }} {
    display: grid;
    grid-template-columns: repeat({{ section.settings.cols_desktop }}, 1fr);
    gap: {{ section.settings.grid_gap }}px;
  }

  .concern-card-{{ section_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1.1; /* Adjusted slightly for better text fit */
    border-radius: {{ section.settings.card_roundness }}px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    text-decoration: none;
    border: 1px solid {{ section.settings.border_color }};
    background: #f4f4f4;
  }

  .concern-card-{{ section_id }}:hover {
    transform: translateY(-8px);
  }

  .concern-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .concern-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s ease;
  }

  .concern-card-{{ section_id }}:hover .concern-bg img {
    transform: scale(1.05);
  }

  .concern-content-{{ section_id }} {
    position: relative;
    z-index: 5;
    padding: 25px;
    margin: 15px;
    border-radius: {{ section.settings.card_roundness | minus: 12 | at_least: 12 }}px;
    background: {{ section.settings.glass_bg_color | color_modify: 'alpha', section.settings.glass_opacity }};
    backdrop-filter: blur({{ section.settings.glass_blur }}px);
    -webkit-backdrop-filter: blur({{ section.settings.glass_blur }}px);
    border: 1px solid rgba(255, 255, 255, 0.4);
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
  }

  /* Card Title - Matched to Ritual Card Title */
  .concern-card-{{ section_id }} h3 {
    color: #ffffff;
    font-size: 22px;
    font-weight: 800;
    margin: 0 0 6px 0;
    letter-spacing: -0.01em;
  }

  /* Card Body - Matched to Step Text */
  .concern-card-{{ section_id }} p {
    color: var(--secondary-text-{{ section_id }});
    font-size: 15px;
    line-height: 1.5;
    margin: 0 0 15px 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Explorer Link - Matched to Pill Label Style */
  .concern-link-{{ section_id }} {
    color: #ffffff;
    font-weight: 800;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    display: flex;
    align-items: center;
    gap: 6px;
    opacity: 0.9;
  }

  @media (max-width: 1024px) {
    .concerns-grid-{{ section_id }} { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 767px) {
    {% if section.settings.hide_cards_mobile %}
      .concerns-grid-{{ section_id }} { display: none !important; }
    {% else %}
       .concerns-grid-{{ section_id }} {
        display: grid !important;
        {% if section.settings.mobile_2x2 %}
          grid-template-columns: repeat(2, 1fr);
          gap: 12px;
        {% else %}
          grid-template-columns: 1fr;
          gap: 20px;
        {% endif %}
      }
    {% endif %}

    .concerns-header-{{ section_id }} h2 { font-size: 28px; }
    .concerns-subheading-{{ section_id }} { font-size: 16px; }

    .concern-content-{{ section_id }} {
      margin: 10px;
      padding: 18px;
    }

    .concern-card-{{ section_id }} h3 { font-size: 18px; }
    .concern-card-{{ section_id }} p { font-size: 13px; margin-bottom: 10px; }
    .concern-link-{{ section_id }} { font-size: 9px; }
  }
{%- endstyle -%}

<section id="concerns-{{ section_id }}">
  <div class="concerns-container-{{ section_id }}">
    <div class="concerns-header-{{ section_id }}">
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="concerns-subheading-{{ section_id }}">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="concerns-grid-{{ section_id }}">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link | default: '#' }}" class="concern-card-{{ section_id }}" {{ block.shopify_attributes }}>
          <div class="concern-bg">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
          <div class="concern-content-{{ section_id }}">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
            <div class="concern-link-{{ section_id }}">
              EXPLORE <span>&rarr;</span>
            </div>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Core Concerns Glass",
  "settings": [
    { "type": "header", "content": "Visibility Settings" },
    { "type": "checkbox", "id": "hide_cards_desktop", "label": "Hide Concern Cards on Desktop", "default": false },
    { "type": "checkbox", "id": "hide_cards_mobile", "label": "Hide Concern Cards on Mobile", "default": false },
    { "type": "header", "content": "Layout Settings" },
    { "type": "range", "id": "max_width", "label": "Max Width", "min": 800, "max": 1600, "step": 50, "default": 1200 },
    { "type": "range", "id": "cols_desktop", "label": "Desktop Columns", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "range", "id": "grid_gap", "label": "Grid Gap", "min": 10, "max": 40, "step": 2, "default": 20 },
    { "type": "checkbox", "id": "mobile_2x2", "label": "Enable 2x2 Grid on Mobile", "default": true },
    { "type": "header", "content": "Typography" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Four Core Concerns" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Targeted solutions for your wellness journey." },
    { "type": "range", "id": "heading_size", "label": "Heading Size", "min": 24, "max": 72, "step": 2, "default": 48 },
    { "type": "select", "id": "heading_align", "label": "Heading Align", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"}], "default": "center" },
    { "type": "header", "content": "Glass Card Styling" },
    { "type": "range", "id": "card_roundness", "label": "Card Corner Radius", "min": 0, "max": 60, "step": 2, "default": 32 },
    { "type": "color", "id": "glass_bg_color", "label": "Glass Color", "default": "#ffffff" },
    { "type": "range", "id": "glass_opacity", "label": "Glass Opacity", "min": 0.1, "max": 0.9, "step": 0.1, "default": 0.6 },
    { "type": "range", "id": "glass_blur", "label": "Glass Blur Intensity", "min": 0, "max": 30, "step": 1, "default": 15 },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#ffffff" },
    { "type": "color", "id": "border_color", "label": "Card Border Color", "default": "transparent" },
    { "type": "header", "content": "Section Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top Padding", "min": 0, "max": 100, "step": 4, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 0, "max": 100, "step": 4, "default": 80 }
  ],
  "blocks": [
    {
      "type": "concern",
      "name": "Concern Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Background Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Sleep" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Can't switch off? Magnesium regulates GABA for deeper rest." },
        { "type": "url", "id": "link", "label": "Card Link" }
      ]
    }
  ],
  "presets": [{ "name": "Core Concerns Glass" }]
}
{% endschema %}