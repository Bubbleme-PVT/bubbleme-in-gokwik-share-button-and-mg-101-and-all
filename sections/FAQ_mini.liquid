{%- comment -%}
  FAQ — Clean Mini Version (Optimized & Standalone)
  - Aligned to Rituals Restoration Typography & Colors
{%- endcomment -%}

{%- liquid
  assign mini_uid = section.id | replace: '-', '' | replace: '_', '' | downcase
  assign one_open = section.settings.one_open
-%}

{%- style -%}
  .faq-mini-{{ mini_uid }} {
    --bm-bg: {{ section.settings.section_bg }};
    --bm-text: #215174;
    --bm-secondary: #4B5563;
    --bm-border: #E2E8F0;
    --bm-closed: #F8FAFC;
    --bm-open: #FFFFFF;
    --bm-iconbg: #E2E8F0;
    --bm-icon: #215174;
    --bm-maxw: {{ section.settings.max_width }}px;
    
    /* Mapped to unique IDs to bypass Shopify cache errors */
    --bm-pt: {{ section.settings.top_space }}px;
    --bm-pb: {{ section.settings.bottom_space }}px;
    
    --bm-itemgap: {{ section.settings.item_gap }}px;
    --bm-radius: {{ section.settings.radius }}px;
    --bm-padx: {{ section.settings.item_padding_x }}px;
    --bm-pady: {{ section.settings.item_padding_y }}px;

    background: var(--bm-bg);
    font-family: 'Inter', 'Montserrat', sans-serif;
  }

  .faq-mini-wrap-{{ mini_uid }} {
    padding: var(--bm-pt) 20px var(--bm-pb);
    max-width: var(--bm-maxw);
    margin: 0 auto;
  }

  .faq-mini-head-{{ mini_uid }} { text-align: center; margin-bottom: {{ section.settings.header_gap }}px; }
  
  .faq-mini-eyebrow-{{ mini_uid }} {
    display: block; 
    margin-bottom: 12px; 
    font-size: 10px;
    letter-spacing: 0.12em; 
    text-transform: uppercase; 
    font-weight: 800;
    color: var(--bm-text);
  }

  .faq-mini-title-{{ mini_uid }} { 
    margin: 0 0 15px; 
    /* Connected the title_size schema setting to the CSS */
    font-size: clamp(28px, 5vw, {{ section.settings.title_size }}px); 
    font-weight: 800; 
    color: var(--bm-text); 
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .faq-mini-sub-{{ mini_uid }} {
    display: block; 
    margin: 0 auto; 
    max-width: 650px;
    font-size: 18px; 
    color: var(--bm-secondary); 
    line-height: 1.6;
  }

  .faq-mini-list-{{ mini_uid }} { display: flex; flex-direction: column; gap: var(--bm-itemgap); }
  .faq-mini-item-{{ mini_uid }} { 
    border-radius: var(--bm-radius); 
    border: 1px solid var(--bm-border); 
    background: var(--bm-closed); 
    overflow: hidden; 
    transition: background 0.25s ease;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
  }
  .faq-mini-item-{{ mini_uid }}.is-open { background: var(--bm-open); border-color: var(--bm-text); }

  .faq-mini-btn-{{ mini_uid }} {
    width: 100%; display: flex; align-items: center; justify-content: space-between;
    padding: var(--bm-pady) var(--bm-padx); background: transparent; border: 0; cursor: pointer; text-align: left;
  }

  .faq-mini-q-{{ mini_uid }} { 
    margin: 0; 
    font-weight: 800; 
    color: var(--bm-text);
    font-size: var(--item-q-d, 18px);
    letter-spacing: -0.01em;
  }
  
  .faq-mini-icon-{{ mini_uid }} {
    width: 36px; height: 36px; border-radius: 50%; background: var(--bm-iconbg);
    display: grid; place-items: center; flex-shrink: 0;
  }
  
  .faq-mini-plus-{{ mini_uid }} { width: 14px; height: 14px; position: relative; transition: transform .3s ease; }
  .faq-mini-plus-{{ mini_uid }}::before, .faq-mini-plus-{{ mini_uid }}::after {
    content: ''; position: absolute; background: var(--bm-icon); top: 50%; left: 50%; transform: translate(-50%, -50%);
  }
  .faq-mini-plus-{{ mini_uid }}::before { width: 14px; height: 2px; }
  .faq-mini-plus-{{ mini_uid }}::after { width: 2px; height: 14px; }
  .is-open .faq-mini-plus-{{ mini_uid }} { transform: rotate(45deg); }

  .faq-mini-panel-{{ mini_uid }} { max-height: 0; overflow: hidden; transition: max-height .3s ease-out; }
  .faq-mini-inner-{{ mini_uid }} { 
    padding: 0 var(--bm-padx) var(--bm-pady); 
    line-height: 1.6; 
    color: var(--bm-secondary);
    font-size: var(--item-a-d, 15px);
  }

  @media screen and (max-width: 767px) {
    .faq-mini-title-{{ mini_uid }} { font-size: 28px; }
    .faq-mini-q-{{ mini_uid }} { font-size: var(--item-q-m, 17px); }
    .faq-mini-inner-{{ mini_uid }} { font-size: var(--item-a-m, 14px); }
  }

  .faq-mini-footer-{{ mini_uid }} { display: flex; justify-content: center; margin-top: 32px; }
  .faq-mini-cta-{{ mini_uid }} {
    display: inline-block; 
    padding: 16px 36px; 
    border: 1.5px solid var(--bm-icon);
    color: var(--bm-icon); 
    text-decoration: none; 
    border-radius: 999px; 
    font-weight: 800;
    text-transform: uppercase;
    font-size: 15px;
    letter-spacing: 0.1em;
  }
{%- endstyle -%}

<section class="faq-mini-{{ mini_uid }}" data-mini-root data-one-open="{{ one_open | json }}">
  <div class="faq-mini-wrap-{{ mini_uid }}">
    
    <div class="faq-mini-head-{{ mini_uid }}">
      {%- if section.settings.eyebrow != blank -%}
        <span class="faq-mini-eyebrow-{{ mini_uid }}">{{ section.settings.eyebrow | escape }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="faq-mini-title-{{ mini_uid }}">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="faq-mini-sub-{{ mini_uid }}">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>

    <div class="faq-mini-list-{{ mini_uid }}">
      {%- for block in section.blocks -%}
        {%- liquid
          assign item_q_d = 18
          assign item_q_m = 17
          assign item_a_d = 15
          assign item_a_m = 14
          
          if block.settings.use_custom_sizes
            assign item_q_d = block.settings.q_size_desktop
            assign item_q_m = block.settings.q_size_mobile
            assign item_a_d = block.settings.a_size_desktop
            assign item_a_m = block.settings.a_size_mobile
          endif
        -%}
        <div class="faq-mini-item-{{ mini_uid }}{% if block.settings.open_by_default %} is-open{% endif %}" 
          data-mini-item {{ block.shopify_attributes }}
          style="--item-q-d: {{ item_q_d }}px; --item-q-m: {{ item_q_m }}px; --item-a-d: {{ item_a_d }}px; --item-a-m: {{ item_a_m }}px;">
          <button type="button" class="faq-mini-btn-{{ mini_uid }}">
            <p class="faq-mini-q-{{ mini_uid }}">{{ block.settings.question | escape }}</p>
            <span class="faq-mini-icon-{{ mini_uid }}"><span class="faq-mini-plus-{{ mini_uid }}"></span></span>
          </button>
          <div class="faq-mini-panel-{{ mini_uid }}">
            <div class="faq-mini-inner-{{ mini_uid }}">{{ block.settings.answer }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
      <div class="faq-mini-footer-{{ mini_uid }}">
        <a href="{{ section.settings.button_link }}" class="faq-mini-cta-{{ mini_uid }}">
          {{ section.settings.button_label | escape }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  (function() {
    const root = document.querySelector('.faq-mini-{{ mini_uid }}');
    if (!root) return;
    const oneOpen = {{ one_open | json }};

    root.addEventListener('click', (e) => {
      const btn = e.target.closest('.faq-mini-btn-{{ mini_uid }}');
      if (!btn) return;
      const item = btn.closest('[data-mini-item]');
      const panel = item.querySelector('.faq-mini-panel-{{ mini_uid }}');
      const isOpen = item.classList.contains('is-open');

      if (!isOpen && oneOpen) {
        root.querySelectorAll('[data-mini-item].is-open').forEach(el => {
          el.classList.remove('is-open');
          el.querySelector('.faq-mini-panel-{{ mini_uid }}').style.maxHeight = null;
        });
      }
      item.classList.toggle('is-open');
      panel.style.maxHeight = item.classList.contains('is-open') ? panel.scrollHeight + "px" : null;
    });

    root.querySelectorAll('.faq-mini-item-{{ mini_uid }}.is-open').forEach(el => {
      const p = el.querySelector('.faq-mini-panel-{{ mini_uid }}');
      p.style.maxHeight = p.scrollHeight + 'px';
    });
  })();
</script>

{% schema %}
{
  "name": "FAQ — Mini Optimized",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Trusted By" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Asked Questions" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Quick answers, no confusion." },
    { "type": "header", "content": "Footer Button" },
    { "type": "text", "id": "button_label", "label": "Button Label", "default": "View more" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    { "type": "header", "content": "Layout" },
    { "type": "checkbox", "id": "one_open", "label": "Only one open at a time", "default": true },
    { "type": "range", "id": "max_width", "label": "Box Width", "min": 400, "max": 1000, "step": 10, "default": 700 },
    { "type": "range", "id": "header_gap", "label": "Header Gap", "min": 10, "max": 100, "step": 2, "default": 32 },
    { "type": "range", "id": "radius", "label": "Corner Radius", "min": 0, "max": 60, "step": 2, "default": 32 },
    { "type": "range", "id": "item_gap", "label": "Gap between items", "min": 4, "max": 50, "step": 1, "default": 12 },
    { "type": "range", "id": "title_size", "label": "Title Size", "min": 20, "max": 100, "step": 1, "default": 42 },
    { "type": "header", "content": "Item Spacing" },
    { "type": "range", "id": "item_padding_x", "label": "Horizontal Padding", "min": 10, "max": 50, "step": 1, "default": 30 },
    { "type": "range", "id": "item_padding_y", "label": "Vertical Padding", "min": 10, "max": 50, "step": 1, "default": 24 },
    { "type": "header", "content": "Section Spacing" },
    { "type": "range", "id": "top_space", "label": "Padding Top", "min": 0, "max": 160, "step": 2, "default": 80 },
    { "type": "range", "id": "bottom_space", "label": "Padding Bottom", "min": 0, "max": 160, "step": 2, "default": 80 },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "section_bg", "label": "Background", "default": "#FFFFFF" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Your question here" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Your answer here</p>" },
        { "type": "checkbox", "id": "open_by_default", "label": "Open by default", "default": false },
        { "type": "header", "content": "Custom Sizes" },
        { "type": "checkbox", "id": "use_custom_sizes", "label": "Use custom sizes", "default": false },
        { "type": "range", "id": "q_size_desktop", "label": "Q Size (Desktop)", "min": 10, "max": 50, "step": 1, "default": 18, "unit": "px" },
        { "type": "range", "id": "q_size_mobile", "label": "Q Size (Mobile)", "min": 10, "max": 50, "step": 1, "default": 17, "unit": "px" },
        { "type": "range", "id": "a_size_desktop", "label": "A Size (Desktop)", "min": 10, "max": 40, "step": 1, "default": 15, "unit": "px" },
        { "type": "range", "id": "a_size_mobile", "label": "A Size (Mobile)", "min": 10, "max": 40, "step": 1, "default": 14, "unit": "px" }
      ]
    }
  ],
  "presets": [{ "name": "FAQ — Mini Optimized" }]
}
{% endschema %}