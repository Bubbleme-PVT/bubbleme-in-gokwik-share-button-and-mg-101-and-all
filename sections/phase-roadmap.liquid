{%- liquid
  assign section_id = section.id | replace: '-', '' | replace: '_', '' | downcase
-%}

{%- style -%}
  :root {
    /* Matched to Global Design Language */
    --primary-blue-{{ section_id }}: #215174;
    --heading-dark-{{ section_id }}: #215174;
    --secondary-text-{{ section_id }}: #4B5563;
    --border-light-{{ section_id }}: #E2E8F0;
    --bg-soft-{{ section_id }}: #F8FAFC;
  }

  .roadmap-{{ section_id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    font-family: 'Inter', 'Montserrat', sans-serif;
    display: block;
    position: relative;
    width: 100%;
  }

  .roadmap-header-{{ section_id }} { 
    margin-bottom: 40px; 
    padding: 0 20px; 
    text-align: center;
  }
  
  /* Overline Label - Matched to Pill Style */
  .roadmap-header-{{ section_id }} .overline-label { 
    font-size: 10px; 
    font-weight: 800; 
    text-transform: uppercase; 
    color: var(--primary-blue-{{ section_id }}); 
    letter-spacing: 0.12em; 
    display: block;
    margin-bottom: 12px;
    opacity: 0.9;
  }

  /* Main Heading - Matched to Rituals H2 */
  .roadmap-header-{{ section_id }} h2 { 
    font-size: clamp(28px, 5vw, 42px); 
    font-weight: 800;
    margin: 0 0 15px 0; 
    color: var(--heading-dark-{{ section_id }}); 
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  /* Subheading - Matched to Rituals Standard */
  .roadmap-subheading-{{ section_id }} {
    font-size: 18px;
    color: var(--secondary-text-{{ section_id }});
    max-width: 750px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .phases-wrapper-{{ section_id }} {
    max-width: {{ section.settings.max_width }}px; 
    margin: 0 auto; 
    padding: 0 20px 60px; 
    display: grid; 
    grid-template-columns: repeat(3, 1fr); 
    gap: 30px; 
    position: relative;
    align-items: stretch;
  }
  
  @media screen and (min-width: 901px) {
    .phases-wrapper-{{ section_id }}::before {
      content: ""; 
      position: absolute; 
      top: 35px; 
      left: 15%; 
      right: 15%; 
      height: 2px;
      background: var(--border-light-{{ section_id }}); 
      z-index: 1;
    }
  }

  .phase-col-{{ section_id }} { 
    position: relative; 
    z-index: 2; 
    text-align: center; 
    display: flex;
    flex-direction: column;
  }

  .phase-indicator-{{ section_id }} {
    width: 74px; height: 74px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px; background: #fff; 
    box-shadow: 0 4px 15px rgba(33, 81, 116, 0.1); 
    border: 2px solid #fff;
    position: relative;
    z-index: 3;
    flex-shrink: 0;
    overflow: hidden;
  }

  .phase-indicator-{{ section_id }} img {
    width: 100%; height: 100%; object-fit: cover;
  }

  /* Phase Number Label - Matched to Pill Style */
  .phase-col-{{ section_id }} h4 { 
    font-size: 10px; 
    font-weight: 800; 
    text-transform: uppercase; 
    color: #94A3B8; 
    margin: 0 0 35px; 
    letter-spacing: 0.12em; 
    flex-shrink: 0;
  }

  .phase-card-{{ section_id }} {
    background: #ffffff; 
    border-radius: 32px; /* Matched Rituals Card Roundness */
    padding: 35px 30px; 
    text-align: left;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03); 
    border: 1px solid var(--border-light-{{ section_id }});
    flex-grow: 1; 
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    display: flex;
    flex-direction: column;
  }
  
  .phase-card-{{ section_id }}:hover {
    transform: translateY(-8px);
    border-color: var(--primary-blue-{{ section_id }});
    box-shadow: 0 20px 40px rgba(33, 81, 116, 0.12);
  }

  /* Card Title - Matched to Ritual Card Titles */
  .phase-card-{{ section_id }} h3 { 
    font-size: 22px; 
    font-weight: 800; 
    margin-bottom: 25px; 
    color: var(--heading-dark-{{ section_id }}); 
    letter-spacing: -0.01em;
  }
  
  .protocol-icon-{{ section_id }} {
    width: 42px; height: 42px; border-radius: 12px; 
    background: var(--bg-soft-{{ section_id }});
    display: flex; align-items: center; justify-content: center; 
    flex-shrink: 0;
    border: 1px solid var(--border-light-{{ section_id }});
    overflow: hidden;
  }

  .protocol-icon-{{ section_id }} img {
    width: 100%; height: 100%; object-fit: contain; padding: 4px;
  }

  /* Protocol Title - Matched to Card Titles (smaller) */
  .protocol-info-{{ section_id }} strong { 
    display: block; 
    font-size: 15px; 
    margin-bottom: 3px; 
    color: var(--heading-dark-{{ section_id }}); 
    font-weight: 800; /* Consistent Extra Bold */
  }
  
  /* Protocol Description - Matched to Step Text */
  .protocol-info-{{ section_id }} p { 
    font-size: 14px; 
    color: var(--secondary-text-{{ section_id }}); 
    margin: 0; 
    line-height: 1.5; 
  }

  @media (max-width: 900px) {
    .roadmap-header-{{ section_id }} h2 { font-size: 28px; }
    .roadmap-subheading-{{ section_id }} { font-size: 16px; }
    
    .phases-wrapper-{{ section_id }} { 
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 20px;
      padding: 0 20px 40px;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    .phases-wrapper-{{ section_id }}::-webkit-scrollbar { display: none; }
    .phase-col-{{ section_id }} { flex: 0 0 85%; scroll-snap-align: center; }
    .phase-card-{{ section_id }} { padding: 30px 20px; }
  }
{%- endstyle -%}

<section class="roadmap-{{ section_id }}">
  <div class="roadmap-header-{{ section_id }}">
    {% if section.settings.label != blank %}
      <span class="overline-label">{{ section.settings.label }}</span>
    {% endif %}
    
    <h2>{{ section.settings.heading }}</h2>
    
    {% if section.settings.subheading != blank %}
      <p class="roadmap-subheading-{{ section_id }}">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>

  <div class="phases-wrapper-{{ section_id }}">
    {% for block in section.blocks %}
      <div class="phase-col-{{ section_id }}" {{ block.shopify_attributes }}>
        <div class="phase-indicator-{{ section_id }}" style="border-bottom: 4px solid #f2ba2f;">
          {% if block.settings.phase_img != blank %}
            {{ block.settings.phase_img | image_url: width: 150 | image_tag: loading: 'lazy' }}
          {% else %}
            <span style="font-size: 24px; font-weight: 800; color: var(--heading-dark-{{ section_id }});">{{ forloop.index }}</span>
          {% endif %}
        </div>
        <h4>PHASE 0{{ forloop.index }}</h4>
        
        <div class="phase-card-{{ section_id }}">
          <h3>{{ block.settings.card_title }}</h3>
          
          <div class="protocol-list-{{ section_id }}">
            {% for i in (1..3) %}
              {% capture p_t %}p{{ i }}_title{% endcapture %}
              {% capture p_d %}p{{ i }}_desc{% endcapture %}
              {% capture p_img %}p{{ i }}_img{% endcapture %}
              {% if block.settings[p_t] != blank %}
                <div class="protocol-item-{{ section_id }}" style="display: flex; gap: 15px; margin-bottom: 20px; align-items: flex-start;">
                  <div class="protocol-icon-{{ section_id }}">
                    {% if block.settings[p_img] != blank %}
                      {{ block.settings[p_img] | image_url: width: 80 | image_tag: loading: 'lazy' }}
                    {% else %}
                      <span style="font-size: 12px; color: #ccc;">•</span>
                    {% endif %}
                  </div>
                  <div class="protocol-info-{{ section_id }}">
                    <strong>{{ block.settings[p_t] }}</strong>
                    <p>{{ block.settings[p_d] }}</p>
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Phase Roadmap Pro",
  "max_blocks": 3,
  "settings": [
    { "type": "header", "content": "Header Content" },
    { "type": "text", "id": "label", "label": "Top Label", "default": "STRATEGIC WELLNESS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your Restoration Roadmap" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "A structured journey designed to transition your body from acute deficiency to long-term vitality." },
    { "type": "header", "content": "Section Style" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "range", "id": "max_width", "label": "Max Width", "min": 1000, "max": 1400, "step": 20, "default": 1200 },
    { "type": "range", "id": "padding_top", "label": "Top Padding", "min": 0, "max": 100, "step": 4, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 0, "max": 100, "step": 4, "default": 80 }
  ],
  "blocks": [
    {
      "type": "phase",
      "name": "Phase",
      "settings": [
        { "type": "color", "id": "phase_color", "label": "Accent Color", "default": "#215174" },
        { "type": "image_picker", "id": "phase_img", "label": "Top Circle Image" },
        { "type": "text", "id": "card_title", "label": "Card Title", "default": "Immediate Relief" },
        { "type": "header", "content": "Protocol 1" },
        { "type": "image_picker", "id": "p1_img", "label": "P1 Image" },
        { "type": "text", "id": "p1_title", "label": "P1 Title", "default": "Magnesium Soak" },
        { "type": "text", "id": "p1_desc", "label": "P1 Desc", "default": "20 mins in 2 cups of Epsom salts." },
        { "type": "header", "content": "Protocol 2" },
        { "type": "image_picker", "id": "p2_img", "label": "P2 Image" },
        { "type": "text", "id": "p2_title", "label": "P2 Title", "default": "Light Sanitation" },
        { "type": "text", "id": "p2_desc", "label": "P2 Desc", "default": "Switch off blue light 1 hour prior." },
        { "type": "header", "content": "Protocol 3" },
        { "type": "image_picker", "id": "p3_img", "label": "P3 Image" },
        { "type": "text", "id": "p3_title", "label": "P3 Title", "default": "Kinetic Release" },
        { "type": "text", "id": "p3_desc", "label": "P3 Desc", "default": "Light stretching to repair mode." }
      ]
    }
  ],
  "presets": [{ "name": "Phase Roadmap Pro" }]
}
{% endschema %}