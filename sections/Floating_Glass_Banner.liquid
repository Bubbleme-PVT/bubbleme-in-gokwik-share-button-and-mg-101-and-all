{%- liquid
  assign std_uid = section.id | replace: '-', '' | replace: '_', '' | downcase
-%}

{%- style -%}
  :root {
    /* Matches Rituals Section Colors */
    --primary-blue-{{ std_uid }}: #215174;
    --heading-dark-{{ std_uid }}: #215174;
    --secondary-text-{{ std_uid }}: #4B5563;
    --border-light-{{ std_uid }}: #E2E8F0;
  }

  .float-banner-{{ std_uid }} {
    background: {{ section.settings.section_bg }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    /* Font family matched to Rituals */
    font-family: "Inter", "Montserrat", sans-serif;
    overflow: hidden;
  }

  .banner-grid-{{ std_uid }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  /* Main Heading Style - Matched to Rituals H2 */
  .banner-content-{{ std_uid }} h2 {
    font-size: clamp(28px, 5vw, {{ section.settings.heading_size }}px);
    line-height: 1.1;
    font-weight: 800;
    margin-bottom: 20px;
    color: var(--heading-dark-{{ std_uid }});
    letter-spacing: -0.02em;
  }
  
  /* Description - Matched to Rituals Subheading */
  .banner-desc-{{ std_uid }} {
    color: var(--secondary-text-{{ std_uid }});
    font-size: 18px;
    line-height: 1.6;
    margin: 0;
  }

  /* --- MINI FLOATING PILL CARD --- */
  .float-card-{{ std_uid }} {
    position: absolute;
    background: {{ section.settings.card_bg_color | color_modify: 'alpha', section.settings.card_opacity }};
    backdrop-filter: blur({{ section.settings.glass_blur }}px);
    -webkit-backdrop-filter: blur({{ section.settings.glass_blur }}px);
    padding: 18px 30px; 
    border-radius: 100px; 
    border: 1px solid rgba(255, 255, 255, 0.4);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
    z-index: 5;
    width: auto;
    min-width: {{ section.settings.card_width }}px;
    pointer-events: none;
    transition: transform 0.2s ease-out;
    bottom: {{ section.settings.card_pos_y }}%;
    left: {{ section.settings.card_pos_x }}px;
    display: flex;
    justify-content: space-between;
    gap: 30px; 
  }

  .pill-col { display: flex; flex-direction: column; text-align: left; }
  
  .pill-label { 
    font-size: 10px; 
    font-weight: 800; 
    color: var(--primary-blue-{{ std_uid }}); 
    text-transform: uppercase; 
    letter-spacing: 0.12em;
    margin-bottom: 4px;
    opacity: 0.9;
    white-space: nowrap;
  }

  .pill-value { 
    font-size: 22px; /* Matched to Ritual Card Title Size */
    font-weight: 800; 
    color: var(--heading-dark-{{ std_uid }}); 
    margin: 0;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  .img-wrapper-{{ std_uid }} {
    position: relative;
    border-radius: {{ section.settings.corner_radius }}px;
    line-height: 0;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03); /* Added Rituals subtle shadow */
  }
  
  .img-wrapper-{{ std_uid }} img {
    width: 100%; height: auto; border-radius: {{ section.settings.corner_radius }}px; display: block;
    object-fit: cover;
  }

  .banner-btns { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 15px; }
  
  .btn-std { 
    padding: 16px 36px; border-radius: 100px; font-weight: 700; 
    text-decoration: none; font-size: 15px; transition: all 0.3s ease; text-align: center; 
  }
  
  .btn-primary { background: var(--primary-blue-{{ std_uid }}); color: #ffffff; }
  .btn-secondary { border: 1.5px solid var(--border-light-{{ std_uid }}); color: var(--heading-dark-{{ std_uid }}); background: #ffffff; }
  .btn-primary:hover { opacity: 0.9; transform: translateY(-2px); }

  /* MOBILE RESPONSIVE FIXES */
  @media (max-width: 990px) {
    .banner-grid-{{ std_uid }} { 
      grid-template-columns: 1fr; 
      text-align: center; 
      gap: 0px;
    }
    .banner-visual-{{ std_uid }} { order: 2; }
    
    .float-card-{{ std_uid }} { 
      left: 50% !important; 
      bottom: 20px !important; 
      transform: translateX(-50%) !important; 
      position: absolute; 
      min-width: unset;
      width: 90%; 
      max-width: 340px;
      padding: 12px 20px;
      gap: 15px;
      justify-content: space-around;
    }

    .pill-value { font-size: 18px; }
    .pill-label { font-size: 9px; }
    .banner-btns { justify-content: center; }
  }

  @media (max-width: 480px) {
    .float-card-{{ std_uid }} {
        width: 95%;
        padding: 10px 15px;
    }
    .pill-value { font-size: 16px; }
  }
{%- endstyle -%}

<section class="float-banner-{{ std_uid }}">
  <div class="banner-grid-{{ std_uid }}">
    <div class="banner-content-{{ std_uid }}">
      {% if section.settings.badge != blank %}
        <p style="color: var(--primary-blue-{{ std_uid }}); font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 15px; font-size: 12px;">{{ section.settings.badge }}</p>
      {% endif %}
      <h2>{{ section.settings.title }}</h2>
      <p class="banner-desc-{{ std_uid }}">{{ section.settings.description }}</p>
      
      <div class="banner-btns">
        {% if section.settings.btn_1 != blank %}
          <a href="{{ section.settings.url_1 }}" class="btn-std btn-primary">{{ section.settings.btn_1 }}</a>
        {% endif %}
        {% if section.settings.btn_2 != blank %}
          <a href="{{ section.settings.url_2 }}" class="btn-std btn-secondary">{{ section.settings.btn_2 }}</a>
        {% endif %}
      </div>
    </div>

    <div class="banner-visual-{{ std_uid }}" id="Visual-{{ std_uid }}">
      <div class="img-wrapper-{{ std_uid }}">
        {% if section.settings.main_image != blank %}
          {{ section.settings.main_image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}

        <div class="float-card-{{ std_uid }}" data-speed="{{ section.settings.float_speed }}">
          <div class="pill-col">
            <span class="pill-label">{{ section.settings.stat1_label }}</span>
            <h4 class="pill-value">{{ section.settings.stat1_value }}</h4>
          </div>
          <div class="pill-col">
            <span class="pill-label">{{ section.settings.stat2_label }}</span>
            <h4 class="pill-value">{{ section.settings.stat2_value }}</h4>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    const visual = document.getElementById('Visual-{{ std_uid }}');
    if (!visual) return;
    const card = visual.querySelector('.float-card-{{ std_uid }}');
    const speed = parseFloat(card?.getAttribute('data-speed')) || 0;

    if (speed !== 0) {
      document.addEventListener('mousemove', function(e) {
        if (window.innerWidth < 991) return; 
        const moveX = (window.innerWidth / 2 - e.pageX) / 65;
        const moveY = (window.innerHeight / 2 - e.pageY) / 65;
        card.style.transform = `translate(${moveX * speed}px, ${moveY * speed}px)`;
      }, { passive: true });
    }
  })();
</script>

{% schema %}
{
  "name": "Floating Glass Banner",
  "settings": [
    { "type": "header", "content": "Layout & Media" },
    { "type": "image_picker", "id": "main_image", "label": "Main Image" },
    { "type": "color", "id": "section_bg", "label": "Section Background", "default": "#ffffff" },
    { "type": "range", "id": "max_width", "label": "Max Width", "min": 800, "max": 1600, "step": 10, "default": 1200 },
    { "type": "range", "id": "corner_radius", "label": "Image Rounding", "min": 0, "max": 100, "step": 4, "default": 40 },
    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "heading_size", "label": "Heading Font Size", "min": 30, "max": 80, "step": 1, "default": 56 },
    { "type": "text", "id": "badge", "label": "Badge Text", "default": "EVIDENCE-BASED" },
    { "type": "inline_richtext", "id": "title", "label": "Title", "default": "Understand <em>Magnesium</em>." },
    { "type": "textarea", "id": "description", "label": "Description", "default": "The essential mineral that powers over 300 biochemical reactions." },
    { "type": "header", "content": "Floating Pill Stats" },
    { "type": "text", "id": "stat1_label", "label": "Stat 1 Label", "default": "Body Function" },
    { "type": "text", "id": "stat1_value", "label": "Stat 1 Value", "default": "300+ Reactions" },
    { "type": "text", "id": "stat2_label", "label": "Stat 2 Label", "default": "Modern Diet" },
    { "type": "text", "id": "stat2_value", "label": "Stat 2 Value", "default": "~50% Deficit" },
    { "type": "color", "id": "card_bg_color", "label": "Pill Glass Color", "default": "#ffffff" },
    { "type": "range", "id": "card_opacity", "label": "Glass Transparency", "min": 0.1, "max": 1.0, "step": 0.1, "default": 0.7 },
    { "type": "range", "id": "glass_blur", "label": "Glass Blur Intensity", "min": 0, "max": 30, "step": 1, "default": 12 },
    { "type": "range", "id": "card_width", "label": "Min Pill Width (px)", "min": 250, "max": 500, "step": 5, "default": 380 },
    { "type": "header", "content": "Position & Motion" },
    { "type": "range", "id": "card_pos_x", "label": "Horizontal Offset (px)", "min": -100, "max": 200, "step": 5, "default": -30 },
    { "type": "range", "id": "card_pos_y", "label": "Vertical Offset (%)", "min": 0, "max": 100, "step": 1, "default": 15 },
    { "type": "range", "id": "float_speed", "label": "Motion Speed", "min": -15, "max": 15, "step": 1, "default": -5 },
    { "type": "header", "content": "Buttons" },
    { "type": "text", "id": "btn_1", "label": "Button 1 Label", "default": "Shop Protocol" },
    { "type": "url", "id": "url_1", "label": "Button 1 Link" },
    { "type": "text", "id": "btn_2", "label": "Button 2 Label", "default": "View Science" },
    { "type": "url", "id": "url_2", "label": "Button 2 Link" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top Spacing", "min": 0, "max": 120, "step": 4, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Spacing", "min": 0, "max": 120, "step": 4, "default": 80 }
  ],
  "presets": [{ "name": "Floating Glass Banner" }]
}
{% endschema %}