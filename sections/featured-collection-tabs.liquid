{% comment %}
  Featured Collection Tabs (with full slider)
  Exactly like featured-collection view, with working arrows & scrollbar
{% endcomment %}

{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{%- if settings.swatch_enabled -%}
  {{ 'component-swatch.css' | asset_url | stylesheet_tag }}
{%- endif -%}

<div id="featured-tabs-{{ section.id }}" class="featured-collection-tabs color-{{ section.settings.color_scheme }} {{ section.settings.top_padding }} {{ section.settings.bottom_padding }}">
  <div class="">

    {% if section.settings.heading != blank %}
      <div class="collection__title title-wrapper page-width title-wrapper--no-top-margin text-center md:text-center xbg">
        <div class="inline-block max-w-s xbg">
          <h2 class="section-title title inline-richtext italics-light h3 scroll-trigger animate--fade-in mb-0">
            {{ section.settings.heading }}
          </h2>
        </div>
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <!-- Tabs -->
      <div class="collection-tabs text-center mb-5">
        {% for block in section.blocks %}
          <button
            class="collection-tab-btn{% if forloop.first %} active{% endif %}"
            data-tab="{{ block.id }}"
            style="border:none;background:none;cursor:pointer;padding:8px 18px;font-weight:600;font-size:16px;">
            {{ block.settings.tab_label }}
          </button>
        {% endfor %}
      </div>

      {% for block in section.blocks %}
        {% assign collection = block.settings.tab_collection %}
        <div id="tab-{{ block.id }}" class="collection-tab-content{% if forloop.first %} active{% endif %}" {% unless forloop.first %}style="display:none;"{% endunless %}>

          {% if collection != blank and collection.all_products_count > 0 %}
            {%- assign products_to_show = section.settings.products_to_show -%}
            {%- assign columns_desktop = section.settings.columns_desktop | plus: 0 -%}
            {%- assign columns_mobile = section.settings.columns_mobile | plus: 0 -%}

            {% if section.settings.enable_mobile_slider %}
              <!-- ✅ MOBILE SLIDER ENABLED -->
              <slider-component class="slider-mobile-gutter page-width-desktop slider-component-desktop slider--tablet grid--peek">
                <ul
                  id="Slider-{{ section.id }}-{{ block.id }}"
                  class="section-grid grid product-grid contains-card contains-card--product grid--{{ columns_desktop }}-col-desktop grid--{{ columns_mobile }}-col-tablet-down slider slider--desktop slider--tablet"
                  role="list"
                >
                  {% for product in collection.products limit: products_to_show %}
                    <li class="grid__item slider__slide">
                      {% render 'card-product',
                        card_product: product,
                        section_id: section.id,
                        columns_desktop: section.settings.columns_desktop,
                        columns_mobile: section.settings.columns_mobile
                      %}
                    </li>
                  {% endfor %}
                </ul>

                <div class="slider-buttons page-width no-js-hidden">
                  <button
                    type="button"
                    class="slider-button button-control tap-target slider-button--prev"
                    name="previous"
                    aria-label="Previous slide"
                    aria-controls="Slider-{{ section.id }}-{{ block.id }}">
                    {% render 'icon-caret' %}
                  </button>
                  <button
                    type="button"
                    class="slider-button button-control tap-target slider-button--next"
                    name="next"
                    aria-label="Next slide"
                    aria-controls="Slider-{{ section.id }}-{{ block.id }}">
                    {% render 'icon-caret' %}
                  </button>

                  <div class="slider-scrollbar__track" style="--num-slides: {{ products_to_show }}">
                    <div class="slider-scrollbar__indicator"></div>
                  </div>
                </div>
              </slider-component>
            {% else %}
              <!-- ✅ MOBILE GRID MODE -->
              <div class="mobile-grid-wrapper">
                <ul class="product-grid grid grid--2-col-tablet-down grid--{{ columns_desktop }}-col-desktop">
                  {% for product in collection.products limit: 8 %}
                    <li class="grid__item">
                      {% render 'card-product',
                        card_product: product,
                        section_id: section.id,
                        columns_desktop: section.settings.columns_desktop,
                        columns_mobile: section.settings.columns_mobile
                      %}
                    </li>
                  {% endfor %}
                </ul>
                <div class="text-center mt-4">
                  <a href="{{ collection.url }}" class="button button--primary">View more</a>
                </div>
              </div>
            {% endif %}
          {% else %}
            <p class="text-center">No products found in this collection.</p>
          {% endif %}
        </div>
      {% endfor %}
    {% else %}
      <p class="text-center">Please add collections in Theme Editor.</p>
    {% endif %}
  </div>
</div>

<style>
  div#featured-tabs-template--19121123066033__featured_collection_tabs_nUXaiD{
    padding-top: 25px !important;
  }
  /* ===== Clean Blue Tabs - Simple Shadow Version ===== */
#featured-tabs-{{ section.id }} .collection-tabs {
  display: flex;
  align-items: center;
  justify-content: center;
  overflow-x: auto;
  gap: 0.8rem;
  padding: 12px 16px;
  background: #fff;
  border-radius: 9999px;
  -webkit-overflow-scrolling: touch;
  scroll-behavior: smooth;
  scrollbar-width: none;
}
#featured-tabs-{{ section.id }} .collection-tabs::-webkit-scrollbar { display: none; }

/* --- INACTIVE TAB --- */
#featured-tabs-{{ section.id }} .collection-tab-btn {
  flex: 0 0 auto;
  white-space: nowrap;
  border-radius: 9999px !important;
  padding: 10px 26px !important;
  font-weight: 600 !important;
  font-size: 15px !important;
  border: 1.8px solid #105e94 !important;
  background: #fff !important;
  color: #105e94 !important;
  cursor: pointer !important;
  box-shadow: none !important;
}

/* --- ACTIVE TAB --- */
#featured-tabs-{{ section.id }} .collection-tab-btn.active {
  background: #105e94 !important;
  color: #fff !important;
  border-color: #105e94 !important;
  box-shadow:
    0 4px 10px rgba(16, 94, 148, 0.35),
    0 2px 4px rgba(16, 94, 148, 0.25) !important;
}

/* --- MOBILE RESPONSIVE --- */
@media (max-width: 768px) {
  #featured-tabs-{{ section.id }} .collection-tabs {
    justify-content: flex-start;
    padding: 0.8rem 1rem;
    gap: 0.6rem;
  }
  #featured-tabs-{{ section.id }} .collection-tab-btn {
    flex: 0 0 auto;
    font-size: 14.5px !important;
    padding: 8px 20px !important;
    scroll-snap-align: center;
  }
}

  @media (max-width: 768px){
    .slider.slider--tablet {
      position: relative;
      flex-wrap: inherit;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-behavior: smooth;
      margin-left: var(--px-mobile);
      scroll-margin-left: var(--px-mobile);
      -webkit-overflow-scrolling: touch;
      margin-bottom: 1rem;
      scrollbar-width: thin;
      scrollbar-color: #999 #f1f1f1;
    }

    .slider.slider--tablet::-webkit-scrollbar {
      height: 6px;
    }

    .slider.slider--tablet::-webkit-scrollbar-thumb {
      background-color: #bbb;
      border-radius: 10px;
    }

    .slider.slider--tablet::-webkit-scrollbar-track {
      background: #f1f1f1;
    }
  }

  .collection-tabs {
    display: flex;
    margin-left: var(--px-mobile);
    scroll-margin-left: var(--px-mobile);
    align-items: center;
    justify-content: center;
    gap: 3rem;
  }
  .collection-tab-btn {
    color: #777;
    position: relative;
    transition: all 0.3s ease;
  }
  .collection-tab-btn.active {
    color: #000;
  }
  .collection-tab-btn.active::after {
    content: "";
    position: absolute;
    bottom: -5px;
    left: 0;
    right: 0;
    height: 2px;
    background: currentColor;
  }
  
  .collection-tab-btn {
    background-color: {{ section.settings.tab_bg_color }} !important;
    color: {{ section.settings.tab_text_color }} !important;
    border: 1px solid !important;
    border-radius: 9999px !important;
    padding: 10px 22px !important;
    font-weight: 600 !important;
    font-size: 16px !important;
    border-color: 105e94;
    cursor: pointer !important;
    transition: all 0.3s ease !important;
  }

  #featured-tabs-{{ section.id }} .collection-tab-btn:hover {
    filter: brightness(0.95);
  }

  #featured-tabs-{{ section.id }} .collection-tab-btn.active {
    background-color: {{ section.settings.tab_active_bg_color }} !important;
    color: {{ section.settings.tab_active_text_color }} !important;
  }

  #featured-tabs-{{ section.id }} .collection-tab-btn.active::after {
    content: none !important;
  }

  @media (max-width: 768px) {
    #featured-tabs-{{ section.id }} .collection-tabs {
      overflow-x: auto;
      flex-wrap: nowrap;
      justify-content: flex-start;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      display: flex;
    }
    #featured-tabs-{{ section.id }} .collection-tab-btn {
      flex: 0 0 auto;
      margin-bottom: 10px;
    }
  } 

  .slider--desktop.grid--5-col-desktop:not(.grid--scaled) .grid__item{
    margin-left: var(--px-mobile);
    scroll-margin-left: var(--px-mobile);
  }

  @media (max-width: 768px) {
    .collection-tabs {
      overflow-x: auto;
      overflow-y: hidden;
      flex-wrap: nowrap;
      justify-content: flex-start;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      gap: 0.8rem;
      padding: 0 1rem;
      scrollbar-width: none;
    }

    .collection-tabs::-webkit-scrollbar {
      display: none;
    }

    .collection-tab-btn {
      flex: 0 0 calc(31%);
      text-align: center;
      font-size: 15px !important;
      padding: 8px 16px !important;
    }

    .mobile-grid-wrapper {
      padding: 0 1rem;
    }
    .mobile-grid-wrapper .product-grid {
      gap: 1rem;
    }
    .mobile-grid-wrapper .button {
      margin-top: 1.5rem;
    }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const section = document.querySelector('#featured-tabs-{{ section.id }}');
  if (!section) return;

  const tabs = section.querySelectorAll('.collection-tab-btn');
  const contents = section.querySelectorAll('.collection-tab-content');

  function initCustomSlider(sliderContainer) {
    const slider = sliderContainer.querySelector('ul.slider');
    const slides = slider ? slider.querySelectorAll('.slider__slide') : [];
    const prevBtn = sliderContainer.querySelector('.slider-button--prev');
    const nextBtn = sliderContainer.querySelector('.slider-button--next');
    const scrollTrack = sliderContainer.querySelector('.slider-scrollbar__track .slider-scrollbar__indicator');

    if (!slider || slides.length <= 4) return;

    let slideWidth = slides[0].offsetWidth + 20;
    let currentIndex = 0;

    function updateScroll() {
      const maxScroll = slider.scrollWidth - slider.clientWidth;
      const progress = slider.scrollLeft / maxScroll;
      if (scrollTrack) scrollTrack.style.transform = `scaleX(${progress})`;
    }

    nextBtn?.addEventListener('click', () => {
      currentIndex++;
      slider.scrollBy({ left: slideWidth, behavior: 'smooth' });
      updateScroll();
    });

    prevBtn?.addEventListener('click', () => {
      currentIndex--;
      slider.scrollBy({ left: -slideWidth, behavior: 'smooth' });
      updateScroll();
    });

    slider.addEventListener('scroll', updateScroll);
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');

      contents.forEach(c => (c.style.display = 'none'));
      const target = section.querySelector('#tab-' + tab.dataset.tab);
      if (target) {
        target.style.display = 'block';
        const sliderComponent = target.querySelector('slider-component');
        if (sliderComponent) initCustomSlider(sliderComponent);
      }
    });
  });

  const firstActive = section.querySelector('.collection-tab-content.active slider-component');
  if (firstActive) initCustomSlider(firstActive);
});
</script>

{% schema %}
{
  "name": "Featured Collection Tabs",
  "settings": [
    {
      "type": "color",
      "id": "tab_bg_color",
      "label": "Tab background color",
      "default": "#fce4ec"
    },
    {
      "type": "color",
      "id": "tab_active_bg_color",
      "label": "Active tab background color",
      "default": "#ff4dc4"
    },
    {
      "type": "color",
      "id": "tab_text_color",
      "label": "Tab text color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "tab_active_text_color",
      "label": "Active tab text color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "enable_mobile_slider",
      "label": "Enable slider on mobile",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Collections"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h2",
      "options": [
        { "value": "h4", "label": "Small" },
        { "value": "h3", "label": "Medium" },
        { "value": "h2", "label": "Large" },
        { "value": "h1", "label": "Extra large" }
      ]
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 24,
      "step": 1,
      "default": 6
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "default": "4",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ]
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "default": "2",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "top_padding",
      "label": "Top spacing",
      "default": "pt-s",
      "options": [
        { "value": "pt-0", "label": "0" },
        { "value": "pt-s", "label": "Small" },
        { "value": "pt-s2", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "bottom_padding",
      "label": "Bottom spacing",
      "default": "pb-s",
      "options": [
        { "value": "pb-0", "label": "0" },
        { "value": "pb-s", "label": "Small" },
        { "value": "pb-s2", "label": "Large" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "collection_tab",
      "name": "Collection Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_label",
          "label": "Tab label",
          "default": "Collection name"
        },
        {
          "type": "collection",
          "id": "tab_collection",
          "label": "Select collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collection Tabs",
      "category": "Collection"
    }
  ]
}
{% endschema %}
