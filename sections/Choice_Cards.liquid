{%- liquid
  assign section_id = section.id | replace: '-', '' | replace: '_', '' | downcase
-%}

{%- style -%}
  :root {
    --primary-blue-{{ section_id }}: #215174;
    --border-light-{{ section_id }}: #E2E8F0;
    --success-green: #22c55e;
    --error-red: #ef4444;
  }

  #StorySection-{{ section_id }} {
    display: flex; justify-content: center; align-items: center;
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }}; overflow: hidden;
    min-height: 65vh; font-family: 'Inter', sans-serif;
  }

  .story-wrapper-{{ section_id }} {
    position: relative; width: 90vw; max-width: 400px; aspect-ratio: 1 / 1.3;
  }

  .story-final-message-{{ section_id }} {
    position: absolute; inset: 0; display: flex; flex-direction: column;
    justify-content: center; align-items: center; text-align: center;
    z-index: 1; padding: 20px;
  }

  .story-stack-{{ section_id }} {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    perspective: 1000px; z-index: 5;
  }

  .story-card-{{ section_id }} {
    position: absolute; width: 100%; height: 100%; border-radius: 32px;
    background-color: #fff; background-size: cover; background-position: center;
    box-shadow: 0 20px 40px -10px rgba(0,0,0,0.25);
    border: 1px solid var(--border-light-{{ section_id }});
    /* Smooth standard transition */
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1), opacity 0.4s ease;
    will-change: transform, opacity;
    cursor: grab; opacity: 0; pointer-events: none; overflow: hidden;
  }

  /* SLOW MOTION CLASS FOR BUTTON CLICKS */
  .story-card-{{ section_id }}.slow-swipe {
    transition: transform 1.2s cubic-bezier(0.15, 0, 0.15, 1), opacity 0.8s ease !important;
  }

  .story-card-{{ section_id }}::before,
  .story-card-{{ section_id }}::after {
    content: ''; position: absolute; inset: 0; opacity: 0; pointer-events: none; z-index: 10; transition: opacity 0.3s;
  }
  .story-card-{{ section_id }}::before { background: linear-gradient(to right, transparent, rgba(34, 197, 94, 0.4)); opacity: var(--green, 0); }
  .story-card-{{ section_id }}::after { background: linear-gradient(to left, transparent, rgba(239, 68, 68, 0.4)); opacity: var(--red, 0); }

  .story-card-{{ section_id }}.is-active { opacity: 1; pointer-events: auto; z-index: 50; }
  .story-card-{{ section_id }}.dragging { transition: none; cursor: grabbing; }

  .story-card-{{ section_id }}.is-stacked-1 { opacity: 0.95; z-index: 40; transform: translate3d(0, 12px, -20px) scale(0.96); }
  .story-card-{{ section_id }}.is-stacked-2 { opacity: 0.75; z-index: 30; transform: translate3d(0, 24px, -40px) scale(0.92); }

  .story-card-{{ section_id }}.is-prev {
    opacity: 0; pointer-events: none;
    transform: translate3d(var(--exit-x, -120%), 20px, 0) rotate(var(--exit-rot, -20deg)) !important;
  }

  .choice-controls-{{ section_id }} {
    position: absolute; bottom: -80px; left: 0; width: 100%;
    display: flex; justify-content: center; gap: 30px;
    opacity: 0; pointer-events: none; transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    z-index: 100;
  }
  .choice-controls-{{ section_id }}.is-visible { opacity: 1; pointer-events: auto; bottom: -20px; }

  .choice-btn-{{ section_id }} {
    width: 64px; height: 64px; border-radius: 50%; border: none;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; background: white; box-shadow: 0 10px 25px rgba(0,0,0,0.12);
    transition: 0.2s;
  }
  .choice-btn-{{ section_id }}:hover { transform: translateY(-3px); box-shadow: 0 15px 30px rgba(0,0,0,0.15); }
  .choice-btn-{{ section_id }}:active { transform: scale(0.9); }
  .choice-btn-cross { color: var(--error-red); }
  .choice-btn-tick { color: var(--success-green); }

  .restart-btn-{{ section_id }} {
    position: absolute; bottom: 20px; right: 20px; z-index: 110;
    width: 54px; height: 54px; border-radius: 50%; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    background: white; border: 1px solid var(--border-light-{{ section_id }});
    transform: scale(0); opacity: 0; transition: 0.4s;
  }
  .restart-btn-{{ section_id }}.is-visible { transform: scale(1); opacity: 1; }
{%- endstyle -%}

<div id="StorySection-{{ section_id }}">
  <div class="story-wrapper-{{ section_id }}">
    
    <div class="story-final-message-{{ section_id }}">
      <h2>{{ section.settings.final_heading }}</h2>
      <p>{{ section.settings.final_text }}</p>
    </div>

    <div class="choice-controls-{{ section_id }}" id="Controls-{{ section_id }}">
      <button class="choice-btn-{{ section_id }} choice-btn-cross" onclick="forceSwipe{{ section_id }}(-1)">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
      <button class="choice-btn-{{ section_id }} choice-btn-tick" onclick="forceSwipe{{ section_id }}(1)">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
      </button>
    </div>

    <button class="restart-btn-{{ section_id }}" id="restart-{{ section_id }}" onclick="resetStory{{ section_id }}()">
       <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M23 4v6h-6"></path><path d="M1 20v-6h6"></path><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path></svg>
    </button>

    <div class="story-stack-{{ section_id }}" id="StoryStack-{{ section_id }}">
      {% for block in section.blocks %}
        <div class="story-card-{{ section_id }}" 
             style="background-image: url('{{ block.settings.image | image_url: width: 1000 }}');"
             {{ block.shopify_attributes }}>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/hammer.js/2.0.8/hammer.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  const stack = document.getElementById('StoryStack-{{ section_id }}');
  const cards = Array.from(stack.querySelectorAll('.story-card-{{ section_id }}'));
  const restartBtn = document.getElementById('restart-{{ section_id }}');
  const controls = document.getElementById('Controls-{{ section_id }}');
  let currentIndex = 0;

  function updateUI() {
    cards.forEach((card, index) => {
      card.classList.remove('is-active', 'is-prev', 'is-stacked-1', 'is-stacked-2', 'slow-swipe');
      card.style.transform = '';
      card.style.setProperty('--red', '0');
      card.style.setProperty('--green', '0');
      
      if (index === currentIndex) {
        card.classList.add('is-active');
        setupHammer(card);
      } else if (index < currentIndex) {
        card.classList.add('is-prev');
      } else if (index === currentIndex + 1) {
        card.classList.add('is-stacked-1');
      } else if (index === currentIndex + 2) {
        card.classList.add('is-stacked-2');
      }
    });

    controls.classList.toggle('is-visible', currentIndex === 0 && cards.length > 0);
    restartBtn.classList.toggle('is-visible', currentIndex === cards.length);
  }

  window.forceSwipe{{ section_id }} = function(direction) {
    const card = cards[currentIndex];
    
    // 1. Add slow transition class
    card.classList.add('slow-swipe');
    
    // 2. Turn on the color overlay slightly before moving
    card.style.setProperty(direction > 0 ? '--green' : '--red', '0.6');

    // 3. Move the card out slowly
    // Use setTimeout so the browser registers the class change and color first
    setTimeout(() => {
        card.style.setProperty('--exit-x', direction > 0 ? '140%' : '-140%');
        card.style.setProperty('--exit-rot', direction > 0 ? '35deg' : '-35deg');
        
        currentIndex++;
        // Delay the UI update until the animation is partially complete
        setTimeout(updateUI, 400); 
    }, 50);
  };

  window.resetStory{{ section_id }} = function() {
    currentIndex = 0;
    updateUI();
  };

  function setupHammer(el) {
    const mc = new Hammer(el);
    mc.get('pan').set({ direction: Hammer.DIRECTION_HORIZONTAL, threshold: 5 });

    mc.on('pan', (e) => {
      el.classList.add('dragging');
      let moveX = e.deltaX;
      let rotation = moveX / 15;
      let opacityValue = Math.min(Math.abs(moveX) / 150, 0.7);

      el.style.transform = `translate3d(${moveX}px, ${e.deltaY * 0.1}px, 0) rotate(${rotation}deg)`;
      el.style.setProperty('--green', moveX > 0 ? opacityValue : '0');
      el.style.setProperty('--red', moveX < 0 ? opacityValue : '0');
    });

    mc.on('panend', (e) => {
      el.classList.remove('dragging');
      const vel = Math.abs(e.velocityX);
      const dist = Math.abs(e.deltaX);

      if (dist > 120 || vel > 0.6) {
        el.style.setProperty('--exit-x', e.deltaX > 0 ? '130%' : '-130%');
        el.style.setProperty('--exit-rot', e.deltaX > 0 ? '25deg' : '-25deg');
        currentIndex++;
        updateUI();
      } else {
        el.style.transform = '';
        el.style.setProperty('--red', '0');
        el.style.setProperty('--green', '0');
      }
    });
  }

  updateUI();
});
</script>

{% schema %}
{
  "name": "Choice Cards",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Top Padding", "default": 60 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 140, "step": 5, "unit": "px", "label": "Bottom Padding", "default": 100 },
    { "type": "header", "content": "End State Text" },
    { "type": "text", "id": "final_heading", "label": "Heading", "default": "That's all!" },
    { "type": "textarea", "id": "final_text", "label": "Text", "default": "You've finished the stack." }
  ],
  "blocks": [{ "type": "card", "name": "Card", "settings": [{ "type": "image_picker", "id": "image", "label": "Image" }] }],
  "presets": [{ "name": "Choice Cards" }]
}
{% endschema %}