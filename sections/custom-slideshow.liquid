{% if section.blocks.size > 0 %}
  <style>
    #shopify-section-{{ section.id }} .splide__pagination .splide__pagination__page {
      width: 15px;
      height: 3px;
      border-radius: 3px;
      min-height: unset;
      min-width: unset;
      background: #fff;
      box-shadow: none;
      transform: scale(1);
      opacity: 1;
    }
    #shopify-section-{{ section.id }} .splide__pagination__page.is-active {
      width: 30px;
    }
    #shopify-section-{{ section.id }} .splide__pagination .splide__pagination__page::before {
      content: none;
    }
    #shopify-section-{{ section.id }} .splide__slide img {
      display: block;
      width: 100%;
      height: auto;
      aspect-ratio: var(--custom-slide-aspect-ratio, 16 / 9);
      object-fit: cover;
    }
    #shopify-section-{{ section.id }} .splide:not(.is-active) {
      visibility: visible;
    }
    #shopify-section-{{ section.id }} .splide:not(.is-active) .splide__list {
      transform: unset !important;
      display: flex;
    }
    #shopify-section-{{ section.id }} .splide:not(.is-active) .splide__list .splide__slide {
      min-width: 100%;
    }
    #shopify-section-{{ section.id }} .splide:not(.is-active) .splide__list .splide__slide img {
      width: 100%;
    }
    @media (min-width: 761px) {
      #shopify-section-{{ section.id }} .desktop-hide {
        display: none;
      }
    }
    @media (max-width: 760px) {
      #shopify-section-{{ section.id }} .mobile-hide {
        display: none;
      }
    }
  html:not(.xh) .cs-container img[d-src] {
      opacity: 0;
  }
  </style>

{%- liquid
  assign first_slide = section.blocks.first
  assign desktop_ratio = 1.777
  if first_slide and first_slide.settings.desktop_image != blank and first_slide.settings.desktop_image.aspect_ratio
    assign desktop_ratio = first_slide.settings.desktop_image.aspect_ratio
  endif
-%}
<div class="cs-container {{ section.index }}" style="--custom-slide-aspect-ratio: {{ desktop_ratio }};">
    <div class="splide is-overflow">
      <div class="splide__track">
        <div class="splide__list">
          {% for block in section.blocks %}
            <div class="splide__slide">
              {% if block.settings.link != blank %}<a href="{{ block.settings.link }}">{% endif %}
                {% if section.index < 3 and forloop.first %}
                  {% if block.settings.desktop_image != blank %}
                    {{ block.settings.desktop_image | image_url: width: 3840 | image_tag:
                      loading: 'eager',
                      fetchpriority: 'high',
                      sizes: "100vw",
                      widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
                      class: 'mobile-hide',
                      preload: true
                    }}
                  {% endif %}
                  {% if block.settings.mobile_image != blank %}
                    {{ block.settings.mobile_image | image_url: width: 3840 | image_tag:
                      loading: 'eager',
                      fetchpriority: 'high',
                      sizes: "100vw",
                      widths: '375, 1200',
                      class: 'desktop-hide',
                      preload: true
                    }}
                  {% endif %}
                {% else %}
                  {% if block.settings.desktop_image != blank %}
                    {% assign smallimg = block.settings.desktop_image | image_url: width: 50 %}
                    {{ block.settings.desktop_image | image_url: width: 3840 | image_tag:
                      loading: 'lazy',
                      sizes: "100vw",
                      widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
                      class: 'mobile-hide' | replace: ' src="' , ' src="smallimg" data-li="st" d-src="' | replace: ' srcset="' , ' dt="' | replace: 'smallimg', smallimg
                    }}
                  {% endif %}
                  {% if block.settings.mobile_image != blank %}
                    {% assign smallimg = block.settings.mobile_image | image_url: width: 50 %}
                    {{ block.settings.mobile_image | image_url: width: 3840 | image_tag:
                      loading: 'lazy',
                      sizes: "100vw",
                      widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
                      class: 'desktop-hide' | replace: ' src="' , ' src="smallimg" data-li="st" d-src="' | replace: ' srcset="' , ' dt="' | replace: 'smallimg', smallimg
                    }}
                  {% endif %}
                {% endif %}
              {% if block.settings.link != blank %}</a>{% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
  <link rel="preload" as="style" href="https://cdn.jsdelivr.net/npm/@splidejs/splide@latest/dist/css/splide.min.css" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@splidejs/splide@latest/dist/css/splide.min.css"></noscript>
  <script type="load" d-src="https://cdn.jsdelivr.net/npm/@splidejs/splide@2.4.6/dist/js/splide.min.js"></script>
  <script type="load">
    (function () {
      var sectionEl = document.getElementById('shopify-section-{{ section.id }}');
      if (!sectionEl) return;
      var sliderEl = sectionEl.querySelector('.splide');
      if (!sliderEl) return;

      function mountSplide() {
        if (sliderEl.dataset.splideMounted === 'true' || typeof Splide === 'undefined') return;
        sliderEl.dataset.splideMounted = 'true';
        var splide{{ section.id | replace:'-','_' }} = new Splide('#shopify-section-{{ section.id }} .splide', {
          {% if section.blocks.size > 1 %}type: 'loop',{% endif %}
          {% if section.settings.autoplay %}
            autoplay: true,
            interval: {{ section.settings.autoplay_seconds | times:1000 }},
            pauseOnHover: true,
            pauseOnFocus: true,
          {% endif %}
          autoHeight: false,
          perPage: 1,
          perMove: 1,
          {% if section.blocks.size > 1 %}
            pagination: true,
          {% else %}
            pagination: false,
          {% endif %}
          arrows: false
        });
        splide{{ section.id | replace:'-','_' }}.mount();
      }

      if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function (entries) {
          if (!entries[0].isIntersecting) return;
          mountSplide();
          io.disconnect();
        }, { rootMargin: '200px 0px' });
        io.observe(sectionEl);
      } else {
        mountSplide();
      }
    })();
  </script>
{% endif %}

{% schema %}
  {
    "name": "Custom Slideshow",
    "settings": [
      {
        "type": "checkbox",
        "id": "autoplay",
        "label": "Autoplay"
      },
      {
        "id": "autoplay_seconds",
        "type": "range",
        "label": "Seconds Between Slides",
        "min": 1,
        "max": 10,
        "step": 1,
        "unit": "s",
        "default": 3
      }
    ],
    "blocks": [
      {
        "type": "slide",
        "name": "Slide",
        "settings": [
          {
            "type": "image_picker",
            "id": "desktop_image",
            "label": "Desktop Image"
          },
          {
            "type": "image_picker",
            "id": "mobile_image",
            "label": "Mobile Image"
          },
          {
            "type": "url",
            "id": "link",
            "label": "Link"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Custom Slideshow"
      }
    ]
  }
{% endschema %}
