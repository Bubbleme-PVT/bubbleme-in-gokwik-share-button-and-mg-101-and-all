{%- liquid
  assign section_id = section.id | replace: '-', '' | replace: '_', '' | downcase
-%}

{%- style -%}
  :root {
    --primary-blue-{{ section_id }}: #215174;
    --border-light-{{ section_id }}: #E2E8F0;
  }

  #StorySection-{{ section_id }} {
    display: flex; justify-content: center; align-items: center;
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }}; overflow: hidden;
    min-height: 50vh; font-family: 'Inter', sans-serif;
  }

  {% if section.settings.hide_on_mobile %}
    @media (max-width: 767px) { #StorySection-{{ section_id }} { display: none !important; } }
  {% endif %}

  {% if section.settings.hide_on_desktop %}
    @media (min-width: 768px) { #StorySection-{{ section_id }} { display: none !important; } }
  {% endif %}

  .story-wrapper-{{ section_id }} {
    position: relative; width: 90vw; max-width: 400px; aspect-ratio: 1 / 1;
  }

  .story-stack-{{ section_id }} {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    perspective: 1000px; z-index: 2;
  }

  .story-card-{{ section_id }} {
    position: absolute; width: 100%; height: 100%; border-radius: 32px;
    background-color: #fff; background-size: cover; background-position: center;
    box-shadow: 0 10px 30px -10px rgba(0,0,0,0.15);
    border: 1px solid var(--border-light-{{ section_id }});
    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1), opacity 0.4s ease;
    will-change: transform, opacity;
    cursor: grab;
    opacity: 0;
    pointer-events: none;
    transform: translate3d(15px, 25px, -40px) rotate(5deg);
  }

  .story-card-{{ section_id }}.is-active {
    opacity: 1; pointer-events: auto; z-index: 20;
    transform: translate3d(0, 0, 0) rotate(0deg);
  }

  .story-card-{{ section_id }}.is-stacked-1 {
    opacity: 0.85; z-index: 15;
    transform: translate3d(8px, 12px, -10px) rotate(2deg) scale(0.98);
  }

  .story-card-{{ section_id }}.is-stacked-2 {
    opacity: 0.65; z-index: 10;
    transform: translate3d(-10px, 22px, -20px) rotate(-3deg) scale(0.96);
  }

  .story-card-{{ section_id }}.is-prev {
    opacity: 0; pointer-events: none; z-index: 25;
    transform: translate3d(-120%, 0, 0) rotate(-15deg);
  }

  /* BLUR & TRANSLUCENT BUTTON STYLES */
  .nav-arrow-{{ section_id }}, .restart-btn-{{ section_id }} {
    background: rgba(255, 255, 255, 0.4); 
    backdrop-filter: blur(12px); 
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.1);
    color: var(--primary-blue-{{ section_id }});
    transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-arrow-{{ section_id }} {
    position: absolute; top: 50%; transform: translateY(-50%);
    width: 52px; height: 52px; border-radius: 50%;
    display: flex; justify-content: center; align-items: center;
    z-index: 100; cursor: pointer;
  }

  .nav-arrow-{{ section_id }}:hover {
    background: rgba(255, 255, 255, 0.6);
    transform: translateY(-50%) scale(1.1);
  }

  .nav-arrow-{{ section_id }}.is-hidden { opacity: 0; pointer-events: none; visibility: hidden; }
  .arrow-left-{{ section_id }} { left: -70px; }
  .arrow-right-{{ section_id }} { right: -70px; }

  @media (max-width: 1100px) {
    .arrow-left-{{ section_id }} { left: 15px; }
    .arrow-right-{{ section_id }} { right: 15px; }
  }

  .restart-btn-{{ section_id }} {
    position: absolute; bottom: 20px; right: 20px; z-index: 110;
    width: 50px; height: 50px; border-radius: 50%; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transform: scale(0); opacity: 0;
  }

  .restart-btn-{{ section_id }}.is-visible { transform: scale(1); opacity: 1; }
  .restart-btn-{{ section_id }}:hover { transform: scale(1.1) rotate(15deg); background: rgba(255, 255, 255, 0.6); }

  .nav-arrow-{{ section_id }} svg, .restart-btn-{{ section_id }} svg { width: 22px; height: 22px; fill: none; stroke: currentColor; stroke-width: 3; }
{%- endstyle -%}

<div id="StorySection-{{ section_id }}">
  <div class="story-wrapper-{{ section_id }}">
    
    <div class="nav-arrow-{{ section_id }} arrow-left-{{ section_id }} is-hidden" id="prevBtn-{{ section_id }}" onclick="moveStory{{ section_id }}(-1)">
      <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </div>
    
    <div class="nav-arrow-{{ section_id }} arrow-right-{{ section_id }}" id="nextBtn-{{ section_id }}" onclick="moveStory{{ section_id }}(1)">
      <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </div>

    <button class="restart-btn-{{ section_id }}" id="restart-{{ section_id }}" onclick="resetStory{{ section_id }}()">
       <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M23 4v6h-6"></path><path d="M1 20v-6h6"></path><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path></svg>
    </button>

    <div class="story-stack-{{ section_id }}" id="StoryStack-{{ section_id }}">
      {% for block in section.blocks %}
        <div class="story-card-{{ section_id }}" 
             style="background-image: url('{{ block.settings.image | image_url: width: 1200 }}');"
             {{ block.shopify_attributes }}>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/hammer.js/2.0.8/hammer.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  const stack = document.getElementById('StoryStack-{{ section_id }}');
  const cards = Array.from(stack.querySelectorAll('.story-card-{{ section_id }}'));
  const nextBtn = document.getElementById('nextBtn-{{ section_id }}');
  const prevBtn = document.getElementById('prevBtn-{{ section_id }}');
  const restartBtn = document.getElementById('restart-{{ section_id }}');
  let currentIndex = 0;

  function updateUI() {
    cards.forEach((card, index) => {
      card.classList.remove('is-active', 'is-prev', 'is-stacked-1', 'is-stacked-2');
      if (index === currentIndex) {
        card.classList.add('is-active');
        setupHammer(card);
      } else if (index < currentIndex) {
        card.classList.add('is-prev');
      } else if (index === currentIndex + 1) {
        card.classList.add('is-stacked-1');
      } else if (index === currentIndex + 2) {
        card.classList.add('is-stacked-2');
      }
    });
    prevBtn.classList.toggle('is-hidden', currentIndex === 0);
    nextBtn.classList.toggle('is-hidden', currentIndex === cards.length - 1);
    restartBtn.classList.toggle('is-visible', currentIndex === cards.length - 1);
  }

  window.moveStory{{ section_id }} = function(direction) {
    let newIndex = currentIndex + direction;
    if (newIndex >= 0 && newIndex < cards.length) {
      currentIndex = newIndex;
      updateUI();
    }
  };

  window.resetStory{{ section_id }} = function() {
    currentIndex = 0;
    updateUI();
  };

  function setupHammer(el) {
    const hammertime = new Hammer(el);
    hammertime.get('swipe').set({ direction: Hammer.DIRECTION_HORIZONTAL });
    hammertime.on('swipeleft', () => moveStory{{ section_id }}(1));
    hammertime.on('swiperight', () => moveStory{{ section_id }}(-1));
  }
  updateUI();
});
</script>

{% schema %}
{
  "name": "Story Card Slider",
  "settings": [
    { "type": "checkbox", "id": "hide_on_mobile", "label": "Hide on Mobile", "default": false },
    { "type": "checkbox", "id": "hide_on_desktop", "label": "Hide on Desktop", "default": false },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Top Padding", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Bottom Padding", "default": 40 }
  ],
  "blocks": [{ "type": "card", "name": "Card", "settings": [{ "type": "image_picker", "id": "image", "label": "Image" }] }],
  "presets": [{ "name": "Story Card Slider" }]
}
{% endschema %}