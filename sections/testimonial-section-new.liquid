{%- comment -%}
Consumer Love – FINAL PERFECT FIX
✅ Exact 4 full cards on desktop (no cut)
✅ Works with Shopify .page-width
✅ Responsive + clean spacing
{%- endcomment -%}

<!-- Swiper CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<section
  class="cl-pro"
  style="
    --cl-bg: {{ section.settings.bg }};
    --cl-text: {{ section.settings.text }};
    --cl-accent: {{ section.settings.accent }};
    --cl-card-bg: {{ section.settings.card_bg }};
    --cl-card-border: {{ section.settings.card_border }};
    --cl-radius: {{ section.settings.radius | default: 16 }}px;
    --cl-shadow: 0 4px 14px rgba(0,0,0,0.06);
  "
>
  <div class="page-width cl-inner">
    {% if section.settings.section_title %}
      <h2 class="cl-title">{{ section.settings.section_title }}</h2>
    {% endif %}

    <div
      class="swiper cl-swiper"
      data-autoplay="{{ section.settings.autoplay }}"
      data-interval="{{ section.settings.interval }}"
      data-desktop="{{ section.settings.desktop_slides }}"
    >
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          {% assign prod = all_products[block.settings.product] %}
          <article class="swiper-slide cl-card">
            <header class="cl-head">
              <div class="cl-avatar">
                {% if block.settings.person_image %}
                  <img loading="lazy" src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNkYAAAAAYAAjCB0C8AAAAASUVORK5CYII=" data-li="st" d-src="{{ block.settings.person_image | img_url: '180x180' }}" alt="{{ block.settings.first_name }}">
                {% endif %}
              </div>
              <div class="cl-person">
                <strong class="cl-name">{{ block.settings.first_name | upcase }} {{ block.settings.last_name | upcase }}</strong>
                {% if block.settings.verified %}
                  <svg class="cl-badge" viewBox="0 0 18 17">
                    <path d="M6.5 16.6L5 14.2L2.2 13.6L2.5 10.7L0.5 8.6L2.5 6.4L2.2 3.6L5 3L6.5 0.5L9.1 1.6L11.8 0.5L13.3 3L16.1 3.6L15.9 6.4L17.8 8.6L15.9 10.7L16.1 13.6L13.3 14.2L11.8 16.7L9.1 15.6L6.5 16.6ZM8.2 11.1L12.7 6.7L12 6.1L8.2 9.8L6.3 8L5.7 8.6L8.2 11.1Z" fill="#3898EF"/>
                  </svg>
                {% endif %}
              </div>
            </header>

            {% if block.settings.show_stars %}
              <div class="cl-stars">
                {% for i in (1..block.settings.stars) %}
                  <svg class="cl-star" viewBox="0 0 26 25"><path d="M12.9 20.5L19 24.2C20.1 24.9 21.5 23.9 21.2 22.7L19.6 15.8L25 11.1C25.9 10.3 25.4 8.7 24.1 8.6L17 8L14.3 1.4C13.8 0.3 12.1 0.3 11.6 1.4L8.8 8L1.8 8.5C0.5 8.6 0 10.3 0.9 11.1L6.3 15.8L4.7 22.7C4.4 23.9 5.8 24.9 6.9 24.2L12.9 20.5Z" fill="gold"/></svg>
                {% endfor %}
              </div>
            {% endif %}

            <div class="cl-text">
              {% if block.settings.title %}<p class="cl-title-sm">{{ block.settings.title }}</p>{% endif %}
              {% if block.settings.body %}<p class="cl-body">{{ block.settings.body }}</p>{% endif %}
            </div>

            {% if prod %}
              <div class="cl-prod">
                <img loading="lazy" src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNkYAAAAAYAAjCB0C8AAAAASUVORK5CYII=" data-li="st" d-src="{{ prod.featured_image | img_url: '100x100' }}" alt="{{ prod.title }}">
                <div class="cl-prod-meta">
                  <p class="cl-rec">{{ block.settings.first_name }} {{ block.settings.rec_text }}</p>
                  <a href="{{ prod.url }}" class="cl-cta">SHOP NOW →</a>
                </div>
              </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>

      <div class="swiper-pagination"></div>
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
    </div>
  </div>
</section>

<style>
  .page-pages-mr-ui-draft .cl-prod {
  display: none;
}
.cl-pro {
  background: var(--cl-bg);
  color: var(--cl-text);
  padding: 0 0 60px 0;
  overflow: hidden;
}
.cl-inner {
  max-width: 100%;
  padding-inline: 2vw;
}
.cl-title {
  text-align: center;
  font-weight: 700;
  font-size: 40px;
  margin-bottom: 40px;
  line-height: 1.3;
}

.cl-card {
  background: var(--cl-card-bg);
  border: 1px solid var(--cl-card-border);
  border-radius: var(--cl-radius);
  padding: 26px 22px;
  box-shadow: var(--cl-shadow);
  transition: all .3s ease;
  height: auto;
}
.cl-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 22px rgba(0,0,0,0.08);
}

.cl-head {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 12px;
}
.cl-avatar img {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  object-fit: cover;
  background: #f3f3f3;
}
.cl-person { position: relative; flex: 1; }
.cl-name {
  font-weight: 600;
  font-size: 13px;
  letter-spacing: 0.3px;
}
.cl-badge {
  width: 14px;
  height: 14px;
  position: absolute;
  top: 0;
  right: 0;
}
.cl-stars {
  display: flex;
  gap: 4px;
  margin: 6px 0 10px;
}
.cl-star { width: 18px; height: 18px; }
.cl-title-sm {
  font-weight: 600;
  font-size: 15px;
  margin-bottom: 4px;
  color: #111;
}
.cl-body {
  font-size: 13.5px;
  line-height: 1.7;
  color: #444;
  margin-bottom: 16px;
}
.cl-prod {
  display: flex;
  align-items: center;
  gap: 10px;
  border-top: 1px solid #eee;
  padding-top: 12px;
}
.cl-prod img {
  width: 60px;
  height: 60px;
  border-radius: 10px;
  object-fit: cover;
}
.cl-rec {
  font-size: 12px;
  margin: 0;
  color: #666;
}
.cl-cta {
  display: inline-block;
  margin-top: 4px;
  color: var(--cl-accent);
  font-weight: 600;
  font-size: 12.5px;
  text-decoration: underline;
  transition: color .3s ease;
}
.cl-cta:hover { color: #000; }

.swiper {
  width: 100%;
  padding-bottom: 50px;
}
.swiper-wrapper {
  width: 100%;
  box-sizing: border-box;
}
.swiper-slide {
  box-sizing: border-box;
}
.swiper-button-prev, .swiper-button-next {
  background: var(--cl-accent);
  color: #fff !important;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  transition: all .3s ease;
}
.swiper-button-prev:hover, .swiper-button-next:hover {
  background: #000;
}
.swiper-button-prev::after, .swiper-button-next::after {
  font-size: 17px;
  font-weight: bold;
}
.swiper-pagination-bullet {
  background: #d6d6d6;
  opacity: 1;
  transition: all .3s ease;
}
.swiper-pagination-bullet-active {
  background: var(--cl-accent);
  width: 18px;
  border-radius: 6px;
}

@media (max-width: 767px) {
  .cl-title{
    font-size: 28px;
  }
  .cl-card { padding: 22px 18px; }
}
</style>

<script type="load" d-src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script type="load">
document.addEventListener("DOMContentLoaded", () => {
  const swiperEl = document.querySelector(".cl-swiper");
  if (!swiperEl) return;

  const autoplayEnabled = swiperEl.dataset.autoplay === "true";
  const autoplaySpeed = parseInt(swiperEl.dataset.interval || 3500, 10);
  const desktopSlides = parseInt(swiperEl.dataset.desktop || 4, 10);

  new Swiper(swiperEl, {
    slidesPerView: 1.15,
    spaceBetween: 18,
    loop: true,
    grabCursor: true,
    pagination: { el: ".swiper-pagination", clickable: true },
    navigation: { nextEl: ".swiper-button-next", prevEl: ".swiper-button-prev" },
    autoplay: autoplayEnabled ? { delay: autoplaySpeed, disableOnInteraction: false } : false,
    breakpoints: {
      640: { slidesPerView: 2, spaceBetween: 22 },
      1024: { slidesPerView: desktopSlides, spaceBetween: 24 },
      1280: { slidesPerView: desktopSlides, spaceBetween: 24 },
      1440: { slidesPerView: desktopSlides, spaceBetween: 24 }
    },
  });
});
</script>


{% schema %}
{
  "name": "Consumer Love",
  "settings": [
    { "type": "text", "id": "section_title", "label": "Section title", "default": "Consumer Love" },
    { "type": "color", "id": "bg", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "text", "label": "Text", "default": "#000000" },
    { "type": "color", "id": "accent", "label": "Accent (Shop Now)", "default": "#0a69b9" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#ffffff" },
    { "type": "color", "id": "card_border", "label": "Card border", "default": "#e5e5e5" },
    { "type": "range", "id": "radius", "label": "Card radius", "min": 4, "max": 30, "step": 1, "default": 16 },
    { "type": "checkbox", "id": "autoplay", "label": "Autoplay", "default": true },
    { "type": "range", "id": "interval", "label": "Autoplay interval (ms)", "min": 2000, "max": 8000, "step": 500, "default": 3500 },
    { "type": "range", "id": "desktop_slides", "label": "Slides per view (Desktop)", "min": 1, "max": 6, "step": 1, "default": 4 }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "image_picker", "id": "person_image", "label": "Reviewer image" },
        { "type": "text", "id": "first_name", "label": "First name" },
        { "type": "text", "id": "last_name", "label": "Last name" },
        { "type": "checkbox", "id": "verified", "label": "Show verified badge", "default": true },
        { "type": "checkbox", "id": "show_stars", "label": "Show stars", "default": true },
        { "type": "range", "id": "stars", "label": "Stars", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "title", "label": "Review title" },
        { "type": "textarea", "id": "body", "label": "Review text" },
        { "type": "product", "id": "product", "label": "Recommended product" },
        { "type": "text", "id": "rec_text", "label": "Recommend text", "default": "Recommends This Product" }
      ]
    }
  ],
  "presets": [{ "name": "Consumer Love" }]
}
{% endschema %}
