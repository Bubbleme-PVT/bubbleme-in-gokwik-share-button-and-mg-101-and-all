{%- liquid
  assign section_id = section.id | replace: '-', '' | replace: '_', '' | downcase
-%}

{%- style -%}
  :root {
    /* Matched to Rituals & Impact Sections */
    --primary-blue-{{ section_id }}: #215174;
    --heading-dark-{{ section_id }}: #215174;
    --secondary-text-{{ section_id }}: #4B5563;
    --border-light-{{ section_id }}: #E2E8F0;
    --bg-soft-{{ section_id }}: #F8FAFC;
  }

  #insight-{{ section_id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    font-family: 'Inter', 'Montserrat', sans-serif;
  }

  .insight-card-{{ section_id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    background: {{ section.settings.card_bg }};
    border-radius: 32px;
    padding: 80px 60px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03); /* Synced Shadow */
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border-light-{{ section_id }});
  }

  /* Glow Effect */
  .insight-card-{{ section_id }}::after {
    content: "";
    position: absolute;
    top: -100px;
    right: -100px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, {{ section.settings.glow_color | color_modify: 'alpha', 0.15 }} 0%, rgba(255,255,255,0) 70%);
    pointer-events: none;
    z-index: 1;
    display: {% if section.settings.show_glow %}block{% else %}none{% endif %};
  }

  .insight-header-{{ section_id }} {
    margin-bottom: 45px;
    position: relative;
    z-index: 2;
  }

  /* Main Heading - Matched to Rituals H2 */
  .insight-header-{{ section_id }} h2 {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 800;
    margin: 0 0 15px 0;
    color: var(--heading-dark-{{ section_id }});
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  /* Subheading - Matched to Rituals Subheading */
  .insight-header-{{ section_id }} p {
    color: var(--secondary-text-{{ section_id }});
    font-size: 18px;
    line-height: 1.6;
    max-width: 600px;
  }

  .insight-choices-{{ section_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
    margin-bottom: 40px;
    position: relative;
    z-index: 2;
  }

  .insight-option {
    display: flex;
    align-items: center;
    background: {{ section.settings.pill_bg }}; 
    padding: 20px 25px;
    border-radius: 100px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1.5px solid var(--border-light-{{ section_id }});
    user-select: none;
  }

  .insight-option:hover {
    border-color: var(--primary-blue-{{ section_id }});
    background: #fff;
  }

  .insight-option.active {
    background: #fff;
    border-color: var(--primary-blue-{{ section_id }});
    box-shadow: 0 4px 15px rgba(33, 81, 116, 0.1);
  }

  .radio-dot {
    width: 20px;
    height: 20px;
    border: 1.5px solid var(--border-light-{{ section_id }});
    border-radius: 50%;
    margin-right: 15px;
    position: relative;
    background: #fff;
    flex-shrink: 0;
    transition: all 0.3s ease;
  }

  .insight-option.active .radio-dot {
    border-color: var(--primary-blue-{{ section_id }});
  }

  .insight-option.active .radio-dot::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 10px;
    height: 10px;
    background: var(--primary-blue-{{ section_id }});
    border-radius: 50%;
  }

  .option-label {
    font-size: 15px;
    font-weight: 700;
    color: var(--heading-dark-{{ section_id }});
  }

  /* Suggestion Box Styling */
  .suggestion-box-{{ section_id }} {
    background: var(--bg-soft-{{ section_id }});
    border: 1px solid var(--border-light-{{ section_id }});
    border-radius: 24px;
    padding: 35px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 30px;
    margin-top: 20px;
    position: relative;
    z-index: 2;
    animation: fadeIn 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Small Label - Matched to Impact/Pill Labels */
  .suggest-label {
    text-transform: uppercase;
    font-size: 10px;
    letter-spacing: 0.12em;
    font-weight: 800;
    color: var(--primary-blue-{{ section_id }}); 
    margin-bottom: 12px;
    display: block;
    opacity: 0.9;
  }

  /* Suggestion Title - Matched to Ritual Card Title */
  .suggest-title {
    font-size: 22px;
    font-weight: 800;
    margin: 0 0 8px 0;
    color: var(--heading-dark-{{ section_id }});
    letter-spacing: -0.01em;
  }

  .suggest-desc {
    font-size: 15px;
    color: var(--secondary-text-{{ section_id }});
    line-height: 1.6;
    margin: 0;
  }

  .explore-btn {
    background: var(--primary-blue-{{ section_id }});
    color: #ffffff;
    padding: 16px 36px;
    border-radius: 100px;
    text-decoration: none;
    font-weight: 700;
    font-size: 15px;
    white-space: nowrap;
    transition: all 0.3s ease;
  }

  .explore-btn:hover {
    opacity: 0.9;
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
  }

  @media (max-width: 767px) {
    .insight-card-{{ section_id }} { padding: 40px 20px; border-radius: 24px; }
    .insight-header-{{ section_id }} h2 { font-size: 28px; }
    .insight-header-{{ section_id }} p { font-size: 16px; }
    .insight-choices-{{ section_id }} { grid-template-columns: 1fr; gap: 10px; }
    .suggestion-box-{{ section_id }} { flex-direction: column; text-align: left; align-items: flex-start; padding: 25px; }
    .explore-btn { width: 100%; text-align: center; }
  }
{%- endstyle -%}

<section id="insight-{{ section_id }}">
  <div class="insight-card-{{ section_id }}" id="insight-container-{{ section_id }}">
    
    <div class="insight-header-{{ section_id }}">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>
    </div>

    <div class="insight-choices-{{ section_id }}">
      {% for block in section.blocks %}
        <div class="insight-option" 
             onclick="handleQuizClick('{{ block.id }}', '{{ block.settings.choice_label | escape }}')"
             data-block-id="{{ block.id }}">
          <div class="radio-dot"></div>
          <span class="option-label">{{ block.settings.choice_label }}</span>
          
          <script type="application/json" id="data-{{ block.id }}">
            {
              "title": {{ block.settings.suggest_title | json }},
              "desc": {{ block.settings.suggest_desc | json }},
              "link": {{ block.settings.suggest_link | json }}
            }
          </script>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.show_suggestion %}
    <div class="suggestion-box-{{ section_id }}" id="sugg-box-{{ section_id }}" style="display: none;">
      <div class="suggest-content">
        <span class="suggest-label">{{ section.settings.sugg_label_text }}</span>
        <h3 class="suggest-title" id="res-title-{{ section_id }}"></h3>
        <p class="suggest-desc" id="res-desc-{{ section_id }}"></p>
      </div>
      <a href="#" class="explore-btn" id="res-link-{{ section_id }}">{{ section.settings.btn_label }}</a>
    </div>
    {% endif %}

  </div>
</section>

<script>
function handleQuizClick(blockId, label) {
  const sectionId = "{{ section_id }}";
  const container = document.getElementById("insight-container-" + sectionId);
  
  container.querySelectorAll('.insight-option').forEach(opt => opt.classList.remove('active'));
  document.querySelector(`[data-block-id="${blockId}"]`).classList.add('active');

  const suggBox = document.getElementById('sugg-box-' + sectionId);
  if (suggBox) {
    const data = JSON.parse(document.getElementById('data-' + blockId).textContent);
    document.getElementById('res-title-' + sectionId).textContent = data.title;
    document.getElementById('res-desc-' + sectionId).textContent = data.desc;
    document.getElementById('res-link-' + sectionId).href = data.link;
    suggBox.style.display = 'flex';
  }
}
</script>

{% schema %}
{
  "name": "Insight Guide Pro",
  "settings": [
    { "type": "header", "content": "Layout & Colors" },
    { "type": "range", "id": "max_width", "label": "Max Width", "min": 600, "max": 1200, "step": 50, "default": 900 },
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#ffffff" },
    { "type": "color", "id": "card_bg", "label": "Card Background", "default": "#ffffff" },
    { "type": "header", "content": "Choice Pills" },
    { "type": "color", "id": "pill_bg", "label": "Pill Background", "default": "#F8FAFC" },
    { "type": "header", "content": "Suggestion Box" },
    { "type": "checkbox", "id": "show_suggestion", "label": "Show Suggestion Box", "default": true },
    { "type": "text", "id": "sugg_label_text", "label": "Upper Label Text", "default": "OUR SUGGESTION" },
    { "type": "text", "id": "btn_label", "label": "Button Text", "default": "Explore Section" },
    { "type": "header", "content": "Glow Effect" },
    { "type": "checkbox", "id": "show_glow", "label": "Show Glow Effect", "default": true },
    { "type": "color", "id": "glow_color", "label": "Glow Color", "default": "#E1F5FE" },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Could this be relevant to you?" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Select how you've been feeling lately." },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Top Padding", "min": 0, "max": 120, "step": 4, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom Padding", "min": 0, "max": 120, "step": 4, "default": 80 }
  ],
  "blocks": [
    {
      "type": "symptom",
      "name": "Symptom Option",
      "settings": [
        { "type": "text", "id": "choice_label", "label": "Choice Label", "default": "Constant Fatigue" },
        { "type": "text", "id": "suggest_title", "label": "Suggestion Title", "default": "Focus on \"Energy\"" },
        { "type": "textarea", "id": "suggest_desc", "label": "Suggestion Text", "default": "Your symptoms suggest a boost in mitochondrial support." },
        { "type": "url", "id": "suggest_link", "label": "Button Link" }
      ]
    }
  ],
  "presets": [{ "name": "Insight Guide Pro" }]
}
{% endschema %}