span class=\"radio-label\">AWB<\/span>\n      <\/label>\n    <\/div>\n\n    <div class=\"input-row\">\n      <input type=\"text\" id=\"track_id_input_final\" placeholder=\"Enter Order ID to search\" onkeypress=\"if(event.key === 'Enter') window.launchShiprocket()\">\n      <p id=\"error-message-final\" class=\"error-text\" style=\"display:none;\"><\/p>\n    <\/div>\n\n    <div class=\"button-row\">\n      <button type=\"button\" onclick=\"window.launchShiprocket()\" class=\"btn-submit\">Submit<\/button>\n    <\/div>\n  <\/div>\n<\/div>","custom_liquid":"","custom_css":".shiprocket-tracking-wrapper {\n  \/* Increased top padding significantly; kept bottom at 4px *\/\n  padding: 50px 15px 4px !important; \n  background-color: transparent;\n  display: flex;\n  justify-content: center;\n  width: 100%;\n}\n\n.tracking-card {\n  background: #ffffff;\n  width: 100%;\n  max-width: 750px; \n  padding: 40px 20px 50px; \n  border-radius: 16px;\n  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);\n  text-align: center;\n  border: 1px solid #eef9ff;\n  box-sizing: border-box;\n}\n\n\/* Rest of your existing styles below *\/\n.track-heading-large {\n  color: #0e436b;\n  font-size: 32px; \n  margin-bottom: 35px;\n  font-weight: 700;\n  margin-top: 0;\n  letter-spacing: -0.5px;\n}\n\n.search-options {\n  display: flex;\n  justify-content: center;\n  gap: 30px; \n  margin-bottom: 25px;\n  flex-wrap: wrap;\n  align-items: center;\n}\n\n.search-by-text {\n  font-weight: 600;\n  color: #0e436b;\n  font-size: 16px;\n}\n\n.radio-item {\n  display: flex;\n  align-items: center;\n  cursor: pointer;\n  font-size: 16px;\n  color: #0e436b;\n}\n\n.radio-item input {\n  margin-right: 8px;\n  accent-color: #0e436b;\n  width: 18px;\n  height: 18px;\n}\n\n.input-row {\n  max-width: 500px; \n  margin: 0 auto;\n}\n\n.input-row input {\n  width: 100%;\n  padding: 14px;\n  border: 1px solid #0e436b;\n  border-radius: 4px;\n  background-color: #eef9ff;\n  box-sizing: border-box;\n  font-size: 14px;\n  color: #000000 !important;\n}\n\n.input-row input::placeholder {\n  color: #000000 !important;\n  opacity: 0.7;\n}\n\n.btn-submit {\n  background-color: #0e436b;\n  color: #ffffff !important;\n  border: none;\n  padding: 16px;\n  width: 100%;\n  max-width: 500px;\n  border-radius: 6px;\n  font-size: 16px;\n  font-weight: 600;\n  cursor: pointer;\n  margin-top: 20px;\n  transition: opacity 0.2s;\n}\n\n.btn-submit:hover { opacity: 0.9; }\n\n.error-text {\n  color: #d93025;\n  font-size: 13px;\n  margin-top: 8px;\n  text-align: center;\n  font-weight: 600;\n}\n\n@media screen and (max-width: 768px) {\n  .shiprocket-tracking-wrapper { padding-top: 80px !important; }\n  .tracking-card { padding: 30px 15px 40px; }\n  .track-heading-large { font-size: 24px; margin-bottom: 25px; }\n}","custom_javascript":"window.updatePlaceholder = function(val) {\n  const input = document.getElementById('track_id_input_final');\n  const error = document.getElementById('error-message-final');\n  \n  if (input) {\n    \/\/ 1. Update the placeholder based on selection\n    input.placeholder = (val === 'order_id') ? \"Enter Order ID to search\" : \"Enter AWB number to search\";\n    \n    \/\/ 2. Refresh the text (Clear the input)\n    input.value = \"\"; \n  }\n  \n  \/\/ 3. Hide any previous error messages\n  if (error) {\n    error.style.display = 'none';\n  }\n};\n\nwindow.launchShiprocket = function() {\n  const input = document.getElementById('track_id_input_final');\n  const error = document.getElementById('error-message-final');\n  const typeSelection = document.querySelector('input[name=\"track_type_final\"]:checked');\n  \n  if (!input || !typeSelection) return;\n  \n  \/\/ Clean the input: remove '#' and whitespace\n  const trackId = input.value.trim().replace(\/#\/g, '');\n  const searchType = typeSelection.value;\n\n  if (!trackId) {\n    error.textContent = \"Please enter tracking details.\";\n    error.style.display = 'block';\n    return;\n  }\n\n  error.style.display = 'none';\n  \n  let finalUrl = \"\";\n\n  if (searchType === 'order_id') {\n    finalUrl = \"https:\/\/bubbleme.shiprocket.co\/tracking\/order\/\" + trackId;\n  } else {\n    \/\/ AWB Logic: Handle Blue Dart (Starts with 77)\n    if (trackId.startsWith('77')) {\n      const baseUrl = \"https:\/\/www.bluedart.com\/web\/guest\/trackdartresultthirdparty\";\n      const params = new URLSearchParams();\n      params.append('trackFor', '0');\n      params.append('trackNo', trackId);\n      finalUrl = baseUrl + \"?\" + params.toString();\n    } else {\n      finalUrl = \"https:\/\/shiprocket.co\/tracking\/\" + trackId;\n    }\n  }\n\n  window.location.href = finalUrl;\n};","desktop_width_percent":100},"blocks":{}},"ai_gen_block_3800258_LkKJAa":{"type":"ai_gen_block_3800258","settings":{"custom_html":"<link rel=\"stylesheet\" href=\"https:\/\/cdnjs.cloudflare.com\/ajax\/libs\/font-awesome\/6.5.1\/css\/all.min.css\">\n\n<div class=\"contact-help-wrapper\">\n  <div class=\"contact-help-card\">\n    <h3 class=\"contact-help-heading\">Need Help with Your Order?<\/h3>\n    \n    <div class=\"contact-help-grid\">\n      <div class=\"contact-help-item\">\n        <span class=\"contact-icon\"><i class=\"fa-solid fa-envelope\"><\/i><\/span>\n        <a href=\"mailto:info@bubbleme.in\">info@bubbleme.in<\/a>\n      <\/div>\n      \n      <div class=\"contact-help-item\">\n        <span class=\"contact-icon\"><i class=\"fa-solid fa-phone\"><\/i><\/span>\n        <a href=\"tel:8288807455\">+91 8288807455<\/a>\n      <\/div>\n      \n      <div class=\"contact-help-item\">\n        <span class=\"contact-icon\"><i class=\"fa-brands fa-whatsapp\"><\/i><\/span>\n        <a href=\"https:\/\/wa.me\/918288807455\">+91 8288807455<\/a>\n      <\/div>\n    <\/div>\n    \n    <p class=\"contact-working-hours\">Monday - Saturday (9:30 AM - 6:30 PM)<\/p>\n  <\/div>\n<\/div>","custom_liquid":"","custom_css":".contact-help-wrapper {\n  \/* Separated padding from tracker section *\/\n  padding: 30px 15px 80px; \n  b