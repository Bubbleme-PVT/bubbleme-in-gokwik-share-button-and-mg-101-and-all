ntent\">\n      <div class=\"hs-header\" style=\"color: #215175;\">\n        {{ ingrediant.step_title }}\n      <\/div>\n      <div class=\"hs-desc\">\n        {{ ingrediant.step_description | metafield_tag }}\n      <\/div>\n    <\/div>\n  <\/div>\n  {% endfor %}\n<\/div>\n{{ product.metafields.custom.how_to_use_with_image.value.more_content | metafield_tag }}\n\n<script>\n document.addEventListener(\"DOMContentLoaded\", function () {\n  let isDragging = false;\n  let startX, scrollLeft;\n\n  const slider = document.querySelector('.npdp-heroslider-2');\n\n  if (!slider) return;\n\n  slider.style.cursor = 'grab';\n\n  slider.addEventListener('mousedown', function (e) {\n    isDragging = true;\n    startX = e.pageX - slider.getBoundingClientRect().left + slider.scrollLeft;\n    scrollLeft = slider.scrollLeft;\n    slider.style.cursor = 'grabbing';\n  });\n\n  document.addEventListener('mouseup', function () {\n    isDragging = false;\n    slider.style.cursor = 'grab';\n  });\n\n  slider.addEventListener('mousemove', function (e) {\n    if (!isDragging) return;\n    const x = e.pageX - slider.getBoundingClientRect().left;\n    const walk = (x - startX) * 1; \/\/ Adjust scroll speed\n    slider.scrollLeft = scrollLeft - walk;\n  });\n});\n\n<\/script>\n{% endif %}","button_text_size":"t3","button_label_1":"","button_link_1":"\/","button_style_1":"primary","button_style_1_show_arrow":false}},"collapsible_row_fmnUi4":{"type":"collapsible_row","settings":{"row_open":true,"heading":"Ingredients","icon":"heart","image_width":20,"row_content":"","page":"","content_embed":"{% if product.metafields.custom.product_ingredient != blank %}\n<div class=\"npdp-heroslider\" style=\"cursor: grab;\">\n  {% assign metadata = product.metafields.custom.product_ingredient.value.ingredients_list.value %}\n  {% for ingrediant in metadata %}\n  <div class=\"hs-element\">\n    {% if ingrediant.image %}\n    <div class=\"hs-image\">\n      {{ ingrediant.image | image_url: width: 200, height: 16